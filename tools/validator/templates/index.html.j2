<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Framing Validator · {{ variant }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; background: #16141a; color: #f5f5f5; margin: 0; padding: 0; }
  header { position: sticky; top: 0; background: #0d0c10; padding: 12px 24px; border-bottom: 1px solid #28252e; z-index: 10; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  header h1 { margin: 0; font-size: 18px; color: #FF6EC7; }
  header label { font-size: 13px; color: #aaa; }
  header select { background: #16141a; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 8px; }
  header button { background: #FF6EC7; color: #0d0c10; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
  .totals { margin-left: auto; font-size: 13px; color: #aaa; }
  #saveStatus { font-size: 12px; color: #666; margin-left: 8px; }

  .help { font-size: 12px; color: #aaa; padding: 8px 24px; background: #1a1820; border-bottom: 1px solid #28252e; line-height: 1.6; }
  .help code { background: #0d0c10; padding: 1px 6px; border-radius: 3px; color: #FF6EC7; font-family: 'JetBrains Mono', monospace; }
  .help b { color: #f5f5f5; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; padding: 24px; }
  .card { background: #1a1820; border: 1px solid #28252e; border-radius: 8px; padding: 12px; }
  .card.reviewed { border-color: #2d4a2d; }
  .card.flagged  { border-color: #f59e0b; }
  .imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; align-items: start; }
  .imgs figure { margin: 0; }
  .imgs figcaption { font-size: 11px; color: #888; margin-top: 2px; }
  .imgs img { width: 100%; height: auto; background: #0d0c10; border-radius: 4px; display: block; }
  .bbox-overlay { position: relative; display: block; line-height: 0; }
  .bbox-overlay .box { position: absolute; border: 0.2vw solid #FF6EC7; pointer-events: none; box-sizing: border-box; }
  /* Secondary detections — other distinct subjects the system clustered.
     Cyan so they contrast against both pink primary and any photo background.
     The ::after pseudo-element shows the DINO confidence as a corner badge —
     low conf (≈0.20) is the noise band where flowers/leaves leak in. */
  .bbox-overlay .box-secondary {
    position: absolute; border: 0.25vw solid #67D4E6;
    pointer-events: none; box-sizing: border-box;
    box-shadow: 0 0 0 0.05vw rgba(0, 0, 0, 0.8);
  }
  .bbox-overlay .box-secondary::after {
    content: attr(data-conf);
    position: absolute; top: -1px; right: -1px;
    background: #67D4E6; color: #0d0c10;
    font: 600 9px/1 'JetBrains Mono', monospace;
    padding: 2px 3px; border-radius: 0 0 0 3px;
  }
  .nocrop { width: 100%; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; background: #0d0c10; color: #666; font-size: 12px; border-radius: 4px; }

  .name { font-size: 14px; margin: 4px 0; color: #f5f5f5; }
  .name code { color: #67D4E6; font-size: 11px; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; margin: 4px 0; font-family: 'JetBrains Mono', monospace; }
  .badge.good          { background: #2d4a2d; color: #a8e6a8; }
  .badge.tight         { background: #2d4a2d; color: #a8e6a8; }
  .badge.wide          { background: #4a3d2d; color: #e6c8a8; }
  .badge.no_bug        { background: #4a2d2d; color: #e6a8a8; }
  .badge.bug_too_small { background: #4a2d2d; color: #e6a8a8; }
  .badge.multi_bug     { background: #4a2d4a; color: #e6a8e6; }
  .badge.poor_contrast { background: #2d3a4a; color: #a8c8e6; }
  .metrics { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; margin: 4px 0; line-height: 1.5; }

  /* Review-row: mark-reviewed + unsure. Mark-reviewed gets full width. */
  .review-row { display: grid; grid-template-columns: 3fr 1fr; gap: 4px; margin-top: 8px; }
  .review-row button {
    padding: 8px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 12px; font-weight: 600; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .review-row button:hover { color: #f5f5f5; border-color: #666; }
  .review-row button.mark-reviewed.active { background: #2d4a2d; color: #a8e6a8; border-color: #4a7a4a; }
  .review-row button.unsure-button.active { background: #28252e; color: #aaa; border-color: #666; }

  /* Rule labeler hint — informational only, not auto-applied (sam3 miscalibrated) */
  .rule-hint { font-size: 11px; font-family: 'JetBrains Mono', monospace; color: #bbb; background: rgba(245,158,11,0.06); border-left: 2px solid rgba(245,158,11,0.4); padding: 4px 8px; margin: 6px 0; }
  .rule-hint code { background: rgba(245,158,11,0.15); color: #f59e0b; padding: 1px 4px; border-radius: 3px; margin-right: 4px; font-size: 10px; }
  .rule-hint.rule-hint-empty { color: #666; background: none; border-left-color: #2a2a2a; }
  .rule-hint.rule-hint-empty em { color: #555; }

  /* 4-column label grid (Phase 2a) */
  .label-columns { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 8px; }
  .col { border: 1px solid #28252e; border-radius: 6px; padding: 6px; display: flex; flex-direction: column; gap: 3px; }
  .col-header { font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #aaa; margin-bottom: 2px; }
  .col.col1 { border-color: rgba(74,198,74,0.3); }
  .col.col1 .col-header { color: #4ac64a; }
  .col.col1 button.active { background: #4ac64a; color: #0d0c10; border-color: #4ac64a; }
  .col.col2 { border-color: rgba(245,158,11,0.3); }
  .col.col2 .col-header { color: #f59e0b; }
  .col.col2 button.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; }
  .col.col3 { border-color: rgba(103,212,230,0.3); }
  .col.col3 .col-header { color: #67D4E6; }
  .col.col3 button.active { background: #67D4E6; color: #0d0c10; border-color: #67D4E6; }
  .col.col4 { border-color: rgba(255,110,199,0.3); }
  .col.col4 .col-header { color: #FF6EC7; }
  .col.col4 button.active { background: #FF6EC7; color: #0d0c10; border-color: #FF6EC7; }
  .col button {
    padding: 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 10px; font-weight: 400; overflow-wrap: anywhere; line-height: 1.25;
    display: flex; align-items: center; justify-content: center; text-align: center;
    min-height: 36px;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .col button:hover { color: #f5f5f5; border-color: #666; }
  .col button.suggested { border-color: #67D4E6; color: #67D4E6; background: rgba(103,212,230,0.10); font-weight: 600; }
  .col.col1 button.suggested { border-color: #4ac64a; color: #4ac64a; background: rgba(74,198,74,0.10); }
  .col.col2 button.suggested { border-color: #f59e0b; color: #f59e0b; background: rgba(245,158,11,0.10); }
  .col.col4 button.suggested { border-color: #FF6EC7; color: #FF6EC7; background: rgba(255,110,199,0.10); }
  .col button.informational { font-style: italic; opacity: 0.75; }
  /* Bbox-only mode: de-emphasize col2-4 */
  body.bbox-only-mode .col.col2,
  body.bbox-only-mode .col.col3,
  body.bbox-only-mode .col.col4 { opacity: 0.4; pointer-events: none; }
  /* Stale label warning */
  .stale-warning { background: rgba(245,158,11,0.15); border: 1px solid #f59e0b; border-radius: 4px;
    color: #f59e0b; font-size: 11px; padding: 4px 8px; margin-bottom: 6px; display: none; }
  .stale-warning.visible { display: block; }
  /* Per-bbox text-label badge */
  .bbox-overlay .box-label { position: absolute; top: 0; left: 0;
    background: rgba(0,0,0,0.7); color: #f5f5f5;
    font: 600 9px/1 'JetBrains Mono', monospace;
    padding: 2px 4px; border-radius: 0 0 3px 0; pointer-events: none;
    white-space: nowrap; max-width: 90%; overflow: hidden; text-overflow: ellipsis; }
  .bbox-overlay .box.box-negative { border-color: #ef4444; }
  .bbox-overlay .box-secondary.box-negative { border-color: #f97316; }

  /* Zoom popup */
  #zoomPopup {
    position: fixed; z-index: 1000;
    pointer-events: none; display: none;
    line-height: 0;
  }
  #zoomPopup img {
    display: block;
    width: auto; height: auto;
    max-width: 55vw; max-height: 96vh;
    object-fit: contain;
    background: #0d0c10;
    border: 0.2vw solid #FF6EC7; border-radius: 0.3vw;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.7);
  }
  #zoomPopup .zoom-bbox {
    position: absolute;
    border: 0.25vw solid #FF6EC7;
    box-sizing: border-box;
    pointer-events: none;
    display: none;
  }
  #zoomPopup .zoom-bbox-secondary {
    position: absolute;
    border: 0.25vw solid #67D4E6;
    box-shadow: 0 0 0 0.05vw rgba(0, 0, 0, 0.8);
    box-sizing: border-box;
    pointer-events: none;
  }
  #zoomPopup .zoom-bbox-secondary::after {
    content: attr(data-conf);
    position: absolute; top: -1px; right: -1px;
    background: #67D4E6; color: #0d0c10;
    font: 600 0.7vw/1 'JetBrains Mono', monospace;
    padding: 0.15vw 0.25vw; border-radius: 0 0 0 0.25vw;
  }
</style>
</head>
<body>
<header>
  <h1>✿ Framing Validator</h1>
  <label>Variant <select id="variant"><option>{{ variant }}</option></select></label>
  <label>Source <select id="source"><option value="all">all</option>{% for s in sources %}<option value="{{ s }}">{{ s }}</option>{% endfor %}</select></label>
  <label>Predicted <select id="quality"><option value="all">all</option><option value="good">good</option><option value="tight">tight</option><option value="wide">wide</option><option value="no_bug">no_bug</option><option value="bug_too_small">bug_too_small</option><option value="multi_bug">multi_bug</option><option value="poor_contrast">poor_contrast</option></select></label>
  <label>Status <select id="reviewStatus"><option value="all">all</option><option value="unreviewed">unreviewed</option><option value="reviewed">reviewed</option><option value="flagged">any flag</option></select></label>
  <label>Sort <select id="sort"><option value="bbox_area">area ↑</option><option value="bbox_long_edge">long-edge px ↑</option><option value="bbox_min_edge">short-edge px ↑</option><option value="confidence">conf ↑</option><option value="lab_delta_e">ΔE ↑</option><option value="subject_sharpness">sharpness ↑</option><option value="random">random</option></select></label>
  <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
    <input type="checkbox" id="bboxOnlyMode" style="width:14px;height:14px;">
    <span style="font-size:13px;color:#f59e0b;font-weight:600;">Bbox-Only Mode</span>
  </label>
  <span class="totals" id="totals">{{ total }} images</span>
  <span id="saveStatus" title="Each click is saved to data/cache/labels.json on the server"></span>
</header>

<div class="help">
  <b>4-column label vocabulary:</b>
  <span style="color:#4ac64a">Col 1 BBox:</span> Did the detector pick the right region? (human-only) ·
  <span style="color:#f59e0b">Col 2 BBox Content:</span> What is inside the bbox? (rule labeler pre-fills) ·
  <span style="color:#67D4E6">Col 3 Mask Rule:</span> Mask-derived quality (rule labeler pre-fills) ·
  <span style="color:#FF6EC7">Col 4 ML Label:</span> Catch-all (human-only today)
  <br><b>System-suggested</b> (rule labeler): shown outlined in column color. <b>Confirmed</b>: filled amber/green/cyan/pink. Click to toggle.
  <br><span style="color:#666">Bbox-Only Mode: focus Col 1 — N/Enter commits Col 1 and auto-accepts rule suggestions for Cols 2-4. Hover any image to zoom. Every click writes to <code>data/cache/labels.json</code>.</span>
</div>

<div class="grid" id="grid"></div>

<script>
const DATA = {{ data_json }};

// 4-column label vocabulary (Phase 2a)
const COL1_BUTTONS = [
  { id: "bbox_correct-subject_not-clipped", label: "Correct\u00a0Not\u00a0Clipped", tip: "Bbox on right bug, full body. DEFAULT \u2014 gate-pass." },
  { id: "bbox_correct-subject_clipped",     label: "Correct\u00a0Clipped",          tip: "Right bug but body cut off by frame or bbox edge." },
  { id: "bbox_wrong-subject",               label: "Wrong\u00a0Subject",            tip: "Bbox on wrong subject (flower, leaf, different bug)." },
];
const COL2_COUNT_BUTTONS = [
  { id: "bbox-content_single",                  label: "Single",              tip: "One bug inside bbox. DEFAULT." },
  { id: "bbox-content_no-bug",                  label: "No\u00a0Bug",         tip: "No insect in bbox at all." },
  { id: "bbox-content_bbox-multibug_unusable",  label: "Multibug\u00a0Unusable", tip: ">=2 bug centers inside bbox \u2014 system auto-set." },
  { id: "bbox-content_bbox-multibug_usable",    label: "Multibug\u00a0Usable",   tip: ">=2 bugs but still drawable (human override)." },
];
const COL2_FLAG_BUTTONS = [
  { id: "bbox-content_subject-too-small", label: "Too\u00a0Small",   tip: "Bug bbox long-edge < 512px.", informational: false },
  { id: "bbox-content_image-multi-bug",   label: "Image\u00a0Multi", tip: ">=2 distinct detections in image \u2014 informational, not a gate signal.", informational: true },
];
const COL3_BUTTONS = [
  { id: "mask_poor-contrast", label: "Poor\u00a0Contrast", tip: "Bug nearly indistinguishable from background." },
  { id: "mask_blur_unusable", label: "Blur\u00a0Unusable",  tip: "Subject too blurred to draw. Mutex with Blur Usable." },
  { id: "mask_blur_usable",   label: "Blur\u00a0Usable",    tip: "Some blur, still drawable. Mutex with Blur Unusable." },
];
const COL4_BUTTONS = [
  { id: "ml_other-bad", label: "Other\u00a0Bad", tip: "Bad for drawing for some other reason." },
];
const COL2_COUNT_IDS = new Set(COL2_COUNT_BUTTONS.map(b => b.id));
const COL3_BLUR_MUTEX = ["mask_blur_unusable", "mask_blur_usable"];
const NEGATIVE_CLASSES = new Set(["flower", "leaf", "stem", "rock"]);

// Source of truth: server-owned `data/cache/labels.json`. We mirror it
// in-memory here; every mutation POSTs the full dict back. localStorage
// is no longer used — origin / port changes don't lose work anymore.
let LABELS = {};
let savePending = 0;

function _emptyLabel() {
  return { col1: null, col2_count: null, col2_flags: [], col3: [], col4: [],
           unsure: false, reviewed_at: null, user_edited: false, variant_tag: null };
}

function notifySaveError(msg) {
  const el = document.getElementById("saveStatus");
  if (el) { el.textContent = "save failed: " + msg; el.style.color = "#ef4444"; }
}

function updateSaveStatus() {
  const el = document.getElementById("saveStatus");
  if (!el) return;
  if (savePending > 0) {
    el.style.color = "#f59e0b";
    el.textContent = "saving" + (savePending > 1 ? " (" + savePending + " queued)" : "") + "…";
    return;
  }
  el.style.color = "#666";
  const n = Object.keys(LABELS).length;
  const reviewed = Object.values(LABELS).filter(v => !!v.reviewed_at).length;
  el.textContent = reviewed + " reviewed · " + n + " labelled · data/cache/labels.json";
}

async function loadLabelsFromServer() {
  try {
    const res = await fetch("/api/labels", { cache: "no-store" });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if (data && typeof data === "object") LABELS = data;
  } catch (e) {
    notifySaveError("load: " + e.message);
  }
}

// Coalesce concurrent saves: while one POST is in flight, new mutations
// just queue a re-send when it returns. This keeps the file write rate
// at one-per-click max even with very fast typing.
let saveQueued = false;
async function saveLabelsToServer() {
  if (savePending > 0) { saveQueued = true; return; }
  savePending++;
  updateSaveStatus();
  while (true) {
    saveQueued = false;
    try {
      const res = await fetch("/api/labels", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(LABELS),
      });
      if (!res.ok) throw new Error("HTTP " + res.status + " " + await res.text());
    } catch (e) {
      notifySaveError("save: " + e.message);
      break;
    }
    if (!saveQueued) break;  // nothing new while we were saving — done
  }
  savePending--;
  updateSaveStatus();
}

// Has the user actually started editing this image?
function isUserEdited(lbl) {
  return !!(lbl && (lbl.user_edited || lbl.col1 || lbl.col2_count ||
    (lbl.col2_flags && lbl.col2_flags.length > 0) ||
    (lbl.col3 && lbl.col3.length > 0) ||
    (lbl.col4 && lbl.col4.length > 0) || lbl.unsure));
}

// Mark the record as user-edited on first interaction. Rule-suggested
// labels are NOT pre-filled — the sam3 rule_labeler is miscalibrated
// (no-bug over-fires 33vs2, multibug_unusable 54vs0, mask_poor-contrast
// 18vs15 w/ only 3 agreeing) and silently endorsing them would
// contaminate the very ground truth needed to re-tune the rule.
// Re-enable pre-fill after threshold sweep produces sam3-tuned values.
function _ensureMaterialized(cur, r) {
  if (cur.user_edited) return;
  cur.user_edited = true;
}

function _rowFor(id) {
  for (const r of DATA) if (r.image_id === id) return r;
  return { suggested_labels: [], variant: null };
}

function _persist(id, cur) {
  cur.reviewed_at = Date.now();
  cur.variant_tag = (_rowFor(id).variant) || "grounding_dino__insectsam";
  if (!cur.user_edited && !cur.col1 && !cur.col2_count &&
      cur.col2_flags.length === 0 && cur.col3.length === 0 &&
      cur.col4.length === 0 && !cur.unsure) {
    delete LABELS[id];
  } else {
    LABELS[id] = cur;
  }
  render();
  saveLabelsToServer();
}

function setCol1(id, btnId) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _rowFor(id));
  cur.col1 = (cur.col1 === btnId) ? null : btnId;
  cur.unsure = false;
  _persist(id, cur);
}
function setCol2Count(id, btnId) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _rowFor(id));
  cur.col2_count = (cur.col2_count === btnId) ? null : btnId;
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol2Flag(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _rowFor(id));
  if (!Array.isArray(cur.col2_flags)) cur.col2_flags = [];  // legacy records lack col2_flags
  const i = cur.col2_flags.indexOf(flagId);
  if (i >= 0) cur.col2_flags.splice(i, 1); else cur.col2_flags.push(flagId);
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol3(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _rowFor(id));
  if (!Array.isArray(cur.col3)) cur.col3 = [];  // legacy records lack col3
  if (COL3_BLUR_MUTEX.includes(flagId))
    cur.col3 = cur.col3.filter(f => !COL3_BLUR_MUTEX.includes(f));
  const i = cur.col3.indexOf(flagId);
  if (i >= 0) cur.col3.splice(i, 1); else cur.col3.push(flagId);
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol4(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _rowFor(id));
  if (!Array.isArray(cur.col4)) cur.col4 = [];  // legacy records lack col4
  const i = cur.col4.indexOf(flagId);
  if (i >= 0) cur.col4.splice(i, 1); else cur.col4.push(flagId);
  cur.unsure = false;
  _persist(id, cur);
}
function setUnsure(id) {
  const cur = LABELS[id] || _emptyLabel();
  cur.user_edited = true;
  cur.unsure = !cur.unsure;
  if (cur.unsure) { cur.col1 = null; cur.col2_count = null; cur.col2_flags = []; cur.col3 = []; cur.col4 = []; }
  _persist(id, cur);
}
function markReviewed(id) {
  const cur = LABELS[id] || _emptyLabel();
  if (cur.reviewed_at && cur.user_edited) { delete LABELS[id]; render(); saveLabelsToServer(); return; }
  _ensureMaterialized(cur, _rowFor(id));
  _persist(id, cur);
}

function fmtPct(n) { return n === null || n === undefined ? "\u2014" : (n * 100).toFixed(1) + "%"; }
function fmtNum(n, d) { return n === null || n === undefined ? "\u2014" : n.toFixed(d); }

// Per-bbox phrase helpers
function _isNegativePhrase(phrase) {
  if (!phrase) return false;
  const s = phrase.startsWith("a ") ? phrase.slice(2) : phrase.startsWith("an ") ? phrase.slice(3) : phrase;
  return NEGATIVE_CLASSES.has(s.toLowerCase());
}
function _phraseBadge(phrase, conf) {
  if (!phrase && conf == null) return "";
  const parts = [phrase, (conf != null ? conf.toFixed(2) : null)].filter(Boolean);
  return '<div class="box-label">' + parts.join("\u00b7") + '</div>';
}

function render() {
  const sf = document.getElementById("source").value;
  const qf = document.getElementById("quality").value;
  const rf = document.getElementById("reviewStatus").value;
  const sortBy = document.getElementById("sort").value;
  const labels = LABELS;
  let rows = DATA.filter(r => sf === "all" || r.source === sf);
  rows = rows.filter(r => qf === "all" || r.framing_quality === qf);
  if (rf !== "all") {
    rows = rows.filter(r => {
      const lbl = labels[r.image_id];
      if (rf === "unreviewed") return !lbl || !lbl.reviewed_at;
      if (rf === "reviewed")   return lbl && lbl.reviewed_at;
      if (rf === "flagged")    return lbl && (
        lbl.col1 || lbl.col2_count ||
        (lbl.col2_flags && lbl.col2_flags.length > 0) ||
        (lbl.col3 && lbl.col3.length > 0) ||
        (lbl.col4 && lbl.col4.length > 0)
      );
      return true;
    });
  }
  if (sortBy === "random") rows.sort(() => Math.random() - 0.5);
  else if (sortBy === "bbox_area") rows.sort((a, b) => (a.bbox_area_ratio ?? 0) - (b.bbox_area_ratio ?? 0));
  else if (sortBy === "bbox_long_edge") rows.sort((a, b) => (a.bbox_long_edge_px ?? 0) - (b.bbox_long_edge_px ?? 0));
  else if (sortBy === "bbox_min_edge") rows.sort((a, b) => (a.bbox_min_edge_px ?? 0) - (b.bbox_min_edge_px ?? 0));
  else if (sortBy === "confidence") rows.sort((a, b) => (a.confidence ?? 0) - (b.confidence ?? 0));
  else if (sortBy === "lab_delta_e") rows.sort((a, b) => (a.lab_delta_e ?? 999) - (b.lab_delta_e ?? 999));
  else if (sortBy === "subject_sharpness") rows.sort((a, b) => (a.subject_sharpness ?? 1e9) - (b.subject_sharpness ?? 1e9));

  document.getElementById("totals").textContent = rows.length + " of " + DATA.length + " images";
  const grid = document.getElementById("grid");
  grid.innerHTML = "";

  const IMPLICIT_VARIANT = "grounding_dino__insectsam";

  for (const r of rows) {
    const lbl = labels[r.image_id] || _emptyLabel();
    const reviewed = !!lbl.reviewed_at;
    const hasAnyFlag = !!(lbl.col1 || lbl.col2_count ||
      (lbl.col2_flags && lbl.col2_flags.length > 0) ||
      (lbl.col3 && lbl.col3.length > 0) ||
      (lbl.col4 && lbl.col4.length > 0));
    const div = document.createElement("div");
    div.className = "card" + (reviewed ? " reviewed" : "") + (hasAnyFlag ? " flagged" : "");
    div.dataset.imageId = r.image_id;

    // Stale-label warning
    const rowVariant = r.variant || IMPLICIT_VARIANT;
    const lblVariant = lbl.variant_tag || IMPLICIT_VARIANT;
    const isStale = !!(lbl.reviewed_at && lblVariant !== rowVariant);
    const staleHTML = isStale
      ? '<div class="stale-warning visible">\u26a0 Label set against variant <b>' + lblVariant + '</b>; current is <b>' + rowVariant + '</b> \u2014 re-review recommended.</div>'
      : '<div class="stale-warning"></div>';

    // Build primary bbox with phrase overlay
    const primaryPhrase = r.text_label || null;
    const primaryConf = r.text_label_score != null ? r.text_label_score : null;
    const primaryNegCls = _isNegativePhrase(primaryPhrase) ? " box-negative" : "";
    const primaryBoxHTML = r.bbox_x !== null
      ? '<div class="box' + primaryNegCls + '" style="left:' + (r.bbox_x*100) + '%;top:' + (r.bbox_y*100) + '%;width:' + (r.bbox_w*100) + '%;height:' + (r.bbox_h*100) + '%">' +
        _phraseBadge(primaryPhrase, primaryConf) + '</div>'
      : '';

    // Secondary bboxes: [x, y, w, h, conf] format from build_html.py
    // secondary_phrases: parallel list of phrase strings
    const secPhrases = r.secondary_phrases || [];
    const secondaryBoxHTML = (r.secondary_bboxes || []).map((b, i) => {
      const conf = (b.length >= 5 && b[4] != null) ? b[4] : null;
      const phrase = secPhrases[i] || null;
      const negCls = _isNegativePhrase(phrase) ? " box-negative" : "";
      const confStr = conf != null ? conf.toFixed(2) : '';
      return '<div class="box-secondary' + negCls + '" data-conf="' + confStr + '" style="left:' + (b[0]*100) + '%;top:' + (b[1]*100) + '%;width:' + (b[2]*100) + '%;height:' + (b[3]*100) + '%">' +
        _phraseBadge(phrase, conf) + '</div>';
    }).join('');

    const boxHTML = primaryBoxHTML + secondaryBoxHTML;
    const cropHTML = r.crop_path
      ? '<img src="' + r.crop_path + '" alt="">'
      : '<div class="nocrop">no crop \u00b7 ' + r.framing_quality + '</div>';

    // 4-column buttons
    const suggested = r.suggested_labels || [];
    const userEdited = isUserEdited(lbl);

    const col1Active = lbl.col1 || null;
    const col1HTML = COL1_BUTTONS.map(b => {
      const cls = col1Active === b.id ? "active" : "";
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="setCol1(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col2CountActive = lbl.col2_count || null;
    const col2CountHTML = COL2_COUNT_BUTTONS.map(b => {
      const isSug = !userEdited && suggested.includes(b.id);
      const isAct = userEdited && col2CountActive === b.id;
      const cls = isAct ? "active" : (isSug ? "suggested" : "");
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="setCol2Count(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col2FlagsActive = lbl.col2_flags || [];
    const col2FlagHTML = COL2_FLAG_BUTTONS.map(b => {
      const isSug = !userEdited && suggested.includes(b.id);
      const isAct = userEdited && col2FlagsActive.includes(b.id);
      const cls = [(isAct ? "active" : (isSug ? "suggested" : "")), (b.informational ? "informational" : "")].filter(Boolean).join(' ');
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol2Flag(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col3Active = lbl.col3 || [];
    const col3HTML = COL3_BUTTONS.map(b => {
      const isSug = !userEdited && suggested.includes(b.id);
      const isAct = userEdited && col3Active.includes(b.id);
      const cls = isAct ? "active" : (isSug ? "suggested" : "");
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol3(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col4Active = lbl.col4 || [];
    const col4HTML = COL4_BUTTONS.map(b => {
      const cls = col4Active.includes(b.id) ? "active" : "";
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol4(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const suggestedHintHTML = suggested.length
      ? '<div class="rule-hint" title="Rule labeler\'s guess. Currently miscalibrated for sam3 — verify before clicking.">rule says: ' +
        suggested.map(s => '<code>' + s + '</code>').join(' ') +
        '</div>'
      : '<div class="rule-hint rule-hint-empty">rule says: <em>(nothing — clean single-bug card)</em></div>';

    const columnsHTML =
      '<div class="label-columns">' +
        '<div class="col col1"><div class="col-header">BBox</div>' + col1HTML + '</div>' +
        '<div class="col col2"><div class="col-header">BBox Content</div>' + col2CountHTML + col2FlagHTML + '</div>' +
        '<div class="col col3"><div class="col-header">Mask Rule</div>' + col3HTML + '</div>' +
        '<div class="col col4"><div class="col-header">ML Label</div>' + col4HTML + '</div>' +
      '</div>';

    div.innerHTML =
      '<div class="imgs">' +
        '<figure>' +
          '<div class="bbox-overlay"><img src="' + r.original_path + '" alt="">' + boxHTML + '</div>' +
          '<figcaption>original \u00b7 primary <span style="color:#FF6EC7">pink</span>' +
            ((r.secondary_bboxes && r.secondary_bboxes.length) ? ' \u00b7 <span style="color:#67D4E6">cyan</span> = ' + r.secondary_bboxes.length + ' other detection' + (r.secondary_bboxes.length === 1 ? '' : 's') : '') +
          '</figcaption>' +
        '</figure>' +
        '<figure>' + cropHTML + '<figcaption>proposed crop \u00b7 what users see</figcaption></figure>' +
      '</div>' +
      '<div class="name">' + (r.common_name || r.taxon_species || "?") + ' <code>\u00b7 ' + r.image_id + '</code></div>' +
      '<span class="badge ' + r.framing_quality + '">' + r.framing_quality + '</span>' +
      '<div class="metrics">' +
        'bbox: ' + fmtPct(r.bbox_area_ratio) + ' (' +
          (r.bbox_long_edge_px !== null && r.bbox_long_edge_px !== undefined ? r.bbox_long_edge_px.toFixed(0) + 'px long' : '\u2014') + ' / ' +
          (r.bbox_min_edge_px !== null && r.bbox_min_edge_px !== undefined ? r.bbox_min_edge_px.toFixed(0) + 'px short' : '\u2014') +
        ') \u00b7 crop fills: ' + fmtPct(r.post_crop_subject_area) + '<br>' +
        'conf: ' + fmtNum(r.confidence, 2) + ' \u00b7 \u0394E: ' + fmtNum(r.lab_delta_e, 1) + ' \u00b7 sharpness: ' + fmtNum(r.subject_sharpness, 0) + '<br>' +
        'detected: ' + r.n_distinct_detections + ' bug' + (r.n_distinct_detections === 1 ? '' : 's') +
        (r.bbox_touches_edge ? ' \u00b7 \u26a0 bbox touches frame edge' : '') +
        (r.gt_iou !== null ? ' \u00b7 gt_iou: ' + r.gt_iou.toFixed(2) : '') +
      '</div>' +
      staleHTML +
      suggestedHintHTML +
      columnsHTML +
      '<div class="review-row">' +
        '<button class="mark-reviewed ' + (reviewed ? 'active' : '') + '" onclick="markReviewed(\'' + r.image_id + '\')" title="Confirms the current labels (accepts the system suggestion if you haven\'t changed anything). Any label edit auto-marks reviewed.">' +
          (reviewed ? '\u2713 reviewed' : '\u2713 mark reviewed') +
        '</button>' +
        '<button class="unsure-button ' + (lbl.unsure ? 'active' : '') + '" onclick="setUnsure(\'' + r.image_id + '\')" title="Ambiguous \u2014 come back later">? unsure</button>' +
      '</div>';
    grid.appendChild(div);
  }
}

document.getElementById("source").addEventListener("change", render);
document.getElementById("quality").addEventListener("change", render);
document.getElementById("reviewStatus").addEventListener("change", render);
document.getElementById("sort").addEventListener("change", render);

// Bbox-only mode toggle
document.getElementById("bboxOnlyMode").addEventListener("change", function() {
  document.body.classList.toggle("bbox-only-mode", this.checked);
});

// Bbox-only mode: Enter / N commits the safe defaults (bbox accept + single
// bug) and nothing else. Rule suggestions for cols 2-4 are NOT auto-applied
// — see _ensureMaterialized note above on rule miscalibration. For anything
// other than a typical single-bug card, click the relevant col2/col3
// buttons explicitly after pressing Enter.
function _commitBboxOnly(id) {
  const cur = LABELS[id] ? Object.assign({}, LABELS[id]) : _emptyLabel();
  cur.col1 = cur.col1 || "bbox_correct-subject_not-clipped";
  if (!cur.col2_count) cur.col2_count = "bbox-content_single";
  if (!Array.isArray(cur.col2_flags)) cur.col2_flags = [];
  if (!Array.isArray(cur.col3)) cur.col3 = [];
  if (!Array.isArray(cur.col4)) cur.col4 = [];
  cur.user_edited = true;
  _persist(id, cur);
}

document.addEventListener("keydown", function(e) {
  if (e.key !== "Enter" && e.key !== "n" && e.key !== "N") return;
  if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
  if (!document.getElementById("bboxOnlyMode").checked) return;
  const card = document.querySelector(".card:not(.reviewed)");
  if (!card || !card.dataset.imageId) return;
  _commitBboxOnly(card.dataset.imageId);
});

// Initial paint with empty LABELS so the grid is up immediately; then fetch
// from server and re-render. The fetch is fast (single file read) and keeps
// the first paint feeling instant on cold loads of the 360-image grid.
render();
updateSaveStatus();
loadLabelsFromServer().then(() => { render(); updateSaveStatus(); });

// Mouse-follow zoom popup with bbox-on-original preservation.
const zoomPopup = document.createElement("div");
zoomPopup.id = "zoomPopup";
const zoomImg = document.createElement("img");
const zoomBox = document.createElement("div");
zoomBox.className = "zoom-bbox";
zoomPopup.appendChild(zoomImg);
zoomPopup.appendChild(zoomBox);
document.body.appendChild(zoomPopup);
const ZOOM_MARGIN_VW = 1;
function vwToPx(v) { return v * window.innerWidth / 100; }
function isZoomTarget(el) {
  return el && el.tagName === "IMG" && el.closest(".imgs figure");
}
document.addEventListener("mouseover", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomImg.src = e.target.src;
  const overlay = e.target.closest(".bbox-overlay");
  // Wipe any previously-mirrored secondary boxes; we'll re-create them below.
  [...zoomPopup.querySelectorAll(".zoom-bbox-secondary")].forEach(n => n.remove());
  const box = overlay ? overlay.querySelector(".box") : null;
  if (box) {
    zoomBox.style.cssText = "position:absolute;box-sizing:border-box;display:block;" + box.style.cssText;
    zoomBox.style.border = "0.25vw solid #FF6EC7";
  } else {
    zoomBox.style.display = "none";
  }
  // Mirror every secondary bbox into the zoomed overlay so they scale with it.
  if (overlay) {
    for (const sb of overlay.querySelectorAll(".box-secondary")) {
      const mirror = document.createElement("div");
      mirror.className = "zoom-bbox-secondary";
      mirror.style.cssText = sb.style.cssText;
      if (sb.dataset.conf) mirror.dataset.conf = sb.dataset.conf;
      zoomPopup.appendChild(mirror);
    }
  }
  zoomPopup.style.display = "block";
});
document.addEventListener("mouseout", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.style.display = "none";
});
document.addEventListener("mousemove", (e) => {
  if (zoomPopup.style.display !== "block") return;
  const r = zoomPopup.getBoundingClientRect();
  const zw = r.width || vwToPx(50);
  const zh = r.height || vwToPx(50);
  const m = vwToPx(ZOOM_MARGIN_VW);
  let x = e.clientX + m;
  let y = e.clientY + m;
  if (x + zw > window.innerWidth - m) x = e.clientX - zw - m;
  if (y + zh > window.innerHeight - m) y = window.innerHeight - zh - m;
  if (x < m) x = m;
  if (y < m) y = m;
  zoomPopup.style.left = x + "px";
  zoomPopup.style.top = y + "px";
});
</script>
</body>
</html>

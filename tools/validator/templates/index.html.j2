<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Framing Validator · {{ variant }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; background: #16141a; color: #f5f5f5; margin: 0; padding: 0; }
  header { position: sticky; top: 0; background: #0d0c10; padding: 12px 24px; border-bottom: 1px solid #28252e; z-index: 10; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  header h1 { margin: 0; font-size: 18px; color: #FF6EC7; }
  header label { font-size: 13px; color: #aaa; }
  header select { background: #16141a; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 8px; }
  header button { background: #FF6EC7; color: #0d0c10; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
  .totals { margin-left: auto; font-size: 13px; color: #aaa; }
  #saveStatus { font-size: 12px; color: #666; margin-left: 8px; }

  .tab-strip { display: flex; gap: 4px; flex-wrap: wrap; padding: 4px 24px; background: #16141a; border-bottom: 1px solid #28252e; }
  .tab-strip button {
    background: #1a1820; color: #aaa; border: 1px solid #444;
    border-radius: 4px; padding: 4px 10px; font-size: 12px; cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
  }
  .tab-strip button.active { background: #4ac64a; color: #0d0c10; border-color: #4ac64a; font-weight: 600; }
  .tab-strip button:hover { color: #f5f5f5; border-color: #666; }

  .help { font-size: 12px; color: #aaa; padding: 8px 24px; background: #1a1820; border-bottom: 1px solid #28252e; line-height: 1.6; }
  .help code { background: #0d0c10; padding: 1px 6px; border-radius: 3px; color: #FF6EC7; font-family: 'JetBrains Mono', monospace; }
  .help b { color: #f5f5f5; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; padding: 24px; }
  .card { background: #1a1820; border: 1px solid #28252e; border-radius: 8px; padding: 12px; }
  .card.reviewed { border-color: #2d4a2d; }
  .card.flagged  { border-color: #f59e0b; }
  /* Unsure overrides reviewed/flagged borders. Slight dim signals "set aside". */
  .card.unsure   { border-color: #666; opacity: 0.78; position: relative; }
  .card.unsure::before {
    content: "UNSURE"; position: absolute; top: 6px; right: 6px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
    color: #ddd; background: #444; padding: 2px 6px; border-radius: 3px;
    font-family: 'JetBrains Mono', monospace; z-index: 2;
  }
  .imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; align-items: start; }
  .imgs figure { margin: 0; }
  .imgs figcaption { font-size: 11px; color: #888; margin-top: 2px; }
  .imgs img { width: 100%; height: auto; background: #0d0c10; border-radius: 4px; display: block; }
  .bbox-overlay { position: relative; display: block; line-height: 0; }
  /* Crisp pink border + 1px black inner outline for contrast on any background.
     z-index: 2 keeps the primary in front when secondaries overlap (otherwise
     the cyan secondary would hide the pink primary). */
  .bbox-overlay .box { position: absolute; border: 2px solid #FF6EC7; pointer-events: none; box-sizing: border-box; box-shadow: 0 0 0 1px rgba(0,0,0,0.8); z-index: 2; }

  /* Bug zoom: square 1:1 container, real <img> inside positioned by JS at onload so we
     can use the image's true natural dimensions and preserve aspect (no background-size
     X% Y% distortion). */
  .bug-zoom { position: relative; width: 100%; aspect-ratio: 1 / 1; background-color: #0d0c10; border-radius: 4px; border: 1px solid #28252e; overflow: hidden; }
  .bug-zoom .bug-zoom-img { position: absolute; display: block; max-width: none; width: auto; height: auto; }
  .bug-zoom-box { position: absolute; border: 2px solid #FF6EC7; box-sizing: border-box; pointer-events: none; box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.8); z-index: 2; }
  /* SAM 3 mask outline overlay — yellow polygon traced from the cached mask,
     positioned to match the bug-zoom img so user can verify mask quality. */
  .bug-zoom-mask-overlay { position: absolute; pointer-events: none; z-index: 1; overflow: visible; }
  .bug-zoom-mask-overlay polygon { fill: rgba(251,191,36,0.08); stroke: #fbbf24; stroke-width: 2; vector-effect: non-scaling-stroke; }
  .bug-zoom-missed { position: absolute; top: 0; left: 0; right: 0; padding: 4px 6px; font-size: 10px; font-family: 'JetBrains Mono', monospace; color: #fbbf24; background: rgba(0,0,0,0.75); text-align: center; z-index: 3; }
  /* Secondary detections — other distinct subjects the system clustered.
     Cyan, z-index 1 so they sit BEHIND the pink primary on overlap. */
  .bbox-overlay .box-secondary {
    position: absolute; border: 2px solid #67D4E6;
    pointer-events: none; box-sizing: border-box;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.8);
    z-index: 1;
  }
  /* Bug-zoom viewport indicator: dashed yellow rectangle on the original image
     marking which region the right-panel bug-zoom is magnifying. Yellow stands
     out against both pink primary and cyan secondary bboxes. */
  .bbox-overlay .bug-zoom-viewport {
    position: absolute;
    border: 2px dashed #fbbf24;
    pointer-events: none;
    box-sizing: border-box;
    z-index: 0;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.7);
  }
  .name { font-size: 14px; margin: 4px 0; color: #f5f5f5; }
  .name code { color: #67D4E6; font-size: 11px; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; margin: 4px 0; font-family: 'JetBrains Mono', monospace; }
  .badge.good          { background: #2d4a2d; color: #a8e6a8; }
  .badge.tight         { background: #2d4a2d; color: #a8e6a8; }
  .badge.wide          { background: #4a3d2d; color: #e6c8a8; }
  .badge.no_bug        { background: #4a2d2d; color: #e6a8a8; }
  .badge.bug_too_small { background: #4a2d2d; color: #e6a8a8; }
  .badge.poor_contrast { background: #2d3a4a; color: #a8c8e6; }
  .metrics { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; margin: 4px 0; line-height: 1.5; }

  /* Review-row: mark-reviewed + unsure. Mark-reviewed gets full width. */
  .review-row { display: grid; grid-template-columns: 3fr 1fr; gap: 4px; margin-top: 8px; }
  .review-row button {
    padding: 8px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 12px; font-weight: 600; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .review-row button:hover { color: #f5f5f5; border-color: #666; }
  .review-row button.mark-reviewed.active { background: #2d4a2d; color: #a8e6a8; border-color: #4a7a4a; }
  .review-row button.unsure-button.active { background: #28252e; color: #aaa; border-color: #666; }

  /* Tab controls: tri-state sort buttons + probability range slider. */
  .tab-controls { display: none; padding: 6px 12px; gap: 12px; align-items: center;
    border-bottom: 1px solid #28252e; background: #14131a; font-size: 12px; color: #aaa;
    font-family: 'JetBrains Mono', monospace; }
  .tab-controls.visible { display: flex; }
  .tab-controls .group { display: inline-flex; gap: 4px; align-items: center; }
  .tab-controls .label { color: #777; }
  .tab-controls button.sort-btn { padding: 4px 10px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer; font-size: 12px; font-family: inherit;
    font-weight: 600; transition: background 0.08s, border-color 0.08s; }
  .tab-controls button.sort-btn:hover { color: #f5f5f5; border-color: #666; }
  .tab-controls button.sort-btn[data-state="asc"],
  .tab-controls button.sort-btn[data-state="desc"] {
    background: #2d4a4a; color: #a8e6e6; border-color: #4a7a7a;
  }
  .prob-range { display: inline-flex; gap: 6px; align-items: center; min-width: 240px; }
  .prob-range input[type="range"] { width: 80px; margin: 0; accent-color: #67D4E6; }
  .prob-range .value { color: #67D4E6; font-weight: 600; min-width: 38px; text-align: center; }
  .prob-range button.range-reset { padding: 2px 6px; font-size: 11px; background: #28252e;
    border: 1px solid #444; color: #aaa; border-radius: 3px; cursor: pointer; }

  .pred-badge { font-size: 9px; color: #67D4E6; font-weight: 400; margin-left: 6px; font-family: 'JetBrains Mono', monospace; }
  .pred-badge.unreliable { color: #888; }
  /* Per-label ML probability chip — shown inline on each col3 button next to
     the label text. Color-coded: red (likely yes), green (likely no), amber (uncertain). */
  .ml-chip { display: inline-block; margin-left: 4px; padding: 1px 4px; border-radius: 8px;
    font-size: 8px; font-weight: 600; color: #0d0c10;
    font-family: 'JetBrains Mono', monospace; vertical-align: middle; }

  /* Rule labeler hint — informational only, not auto-applied (sam3 miscalibrated) */
  .rule-hint { font-size: 11px; font-family: 'JetBrains Mono', monospace; color: #bbb; background: rgba(245,158,11,0.06); border-left: 2px solid rgba(245,158,11,0.4); padding: 4px 8px; margin: 6px 0; }
  .rule-hint code { background: rgba(245,158,11,0.15); color: #f59e0b; padding: 1px 4px; border-radius: 3px; margin-right: 4px; font-size: 10px; }
  .rule-hint.rule-hint-empty { color: #666; background: none; border-left-color: #2a2a2a; }
  .rule-hint.rule-hint-empty em { color: #555; }

  /* 4-column label grid (Phase 2a) */
  .label-columns { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 8px; }
  .col { border: 1px solid #28252e; border-radius: 6px; padding: 6px; display: flex; flex-direction: column; gap: 3px; }
  .col-header { font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #aaa; margin-bottom: 2px; }
  .col.col1 { border-color: rgba(74,198,74,0.3); }
  .col.col1 .col-header { color: #4ac64a; }
  .col.col1 button.active { background: #4ac64a; color: #0d0c10; border-color: #4ac64a; }
  .col.col2 { border-color: rgba(245,158,11,0.3); }
  .col.col2 .col-header { color: #f59e0b; }
  .col.col2 button.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; }
  .col.col3 { border-color: rgba(103,212,230,0.3); }
  .col.col3 .col-header { color: #67D4E6; }
  .col.col3 button.active { background: #67D4E6; color: #0d0c10; border-color: #67D4E6; }
  .col.col4 { border-color: rgba(255,110,199,0.3); }
  .col.col4 .col-header { color: #FF6EC7; }
  .col.col4 button.active { background: #FF6EC7; color: #0d0c10; border-color: #FF6EC7; }
  .col button {
    padding: 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 10px; font-weight: 400; overflow-wrap: anywhere; line-height: 1.25;
    display: flex; align-items: center; justify-content: center; text-align: center;
    min-height: 36px;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .col button:hover { color: #f5f5f5; border-color: #666; }
  .col button.informational { font-style: italic; opacity: 0.75; }
  /* Dim + disable buttons that don't apply given current bbox state.
     For has-bbox cards: the "Should Have Bbox" button is dimmed.
     For no-bbox cards: all bbox-derived buttons are dimmed. */
  .col button.nobbox-dim { opacity: 0.25; cursor: not-allowed; pointer-events: none; }
  .col button.nobbox-dim:hover { color: inherit; border-color: inherit; }
  /* Stale label warning */
  .stale-warning { background: rgba(245,158,11,0.15); border: 1px solid #f59e0b; border-radius: 4px;
    color: #f59e0b; font-size: 11px; padding: 4px 8px; margin-bottom: 6px; display: none; }
  .stale-warning.visible { display: block; }
  /* Phrase + confidence summary list shown below the images (replaces the
     on-bbox label which got truncated and covered the subject). */
  .phrase-summary { font: 11px/1.5 'JetBrains Mono', monospace; color: #aaa; margin: 4px 0 6px; padding: 4px 8px; background: rgba(255,255,255,0.03); border-radius: 4px; list-style: none; }
  .phrase-summary li { margin: 0; }
  .bbox-overlay .box.box-negative { border-color: #ef4444; }
  .bbox-overlay .box-secondary.box-negative { border-color: #f97316; }

  /* Zoom popup */
  #zoomPopup {
    position: fixed; z-index: 1000;
    pointer-events: none; display: none;
    line-height: 0;
  }
  #zoomPopup img {
    display: block;
    width: auto; height: auto;
    max-width: 55vw; max-height: 96vh;
    object-fit: contain;
    background: #0d0c10;
    border: 0.2vw solid #FF6EC7; border-radius: 0.3vw;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.7);
  }
  /* Bug-zoom-clone img inside the popup needs to ESCAPE the #zoomPopup img
     constraints (max-width 55vw + object-fit contain), because _positionBugZoom
     sizes the img to ~tens of thousands of px and positions via negative
     left/top so the bbox region falls within the 50vw clone container. */
  #zoomPopup .bug-zoom-clone .bug-zoom-img {
    max-width: none !important; max-height: none !important;
    object-fit: initial; background: transparent;
    border: none; border-radius: 0; box-shadow: none;
  }
  #zoomPopup .zoom-bbox {
    position: absolute;
    border: 0.25vw solid #FF6EC7;
    box-sizing: border-box;
    pointer-events: none;
    display: none;
    z-index: 2;
  }
  #zoomPopup .zoom-bbox-secondary {
    position: absolute;
    border: 0.25vw solid #67D4E6;
    box-shadow: 0 0 0 0.05vw rgba(0, 0, 0, 0.8);
    box-sizing: border-box;
    pointer-events: none;
    z-index: 1;
  }
</style>
</head>
<body>
<header>
  <h1>✿ Framing Validator</h1>
  <label>Variant <select id="variant"><option>{{ variant }}</option></select></label>
  <label>Source <select id="source"><option value="all">all</option>{% for s in sources %}<option value="{{ s }}">{{ s }}</option>{% endfor %}</select></label>
  <label>Predicted <select id="quality"><option value="all">all</option><option value="good">good</option><option value="tight">tight</option><option value="wide">wide</option><option value="no_bug">no_bug</option><option value="bug_too_small">bug_too_small</option><option value="poor_contrast">poor_contrast</option></select></label>
  <label>Status <select id="reviewStatus"><option value="all">all</option><option value="unreviewed">unreviewed</option><option value="reviewed">reviewed</option><option value="unsure">unsure</option><option value="flagged">any flag</option></select></label>
  <label>Sort <select id="sort"><option value="bbox_area">area ↑</option><option value="bbox_long_edge">long-edge px ↑</option><option value="bbox_min_edge">short-edge px ↑</option><option value="confidence">detector conf ↑</option><option value="lab_delta_e">ΔE ↑</option><option value="subject_sharpness">sharpness ↑</option><option value="random">random</option></select></label>
  <span class="totals" id="totals">{{ total }} images</span>
  <span id="saveStatus" title="Each click is saved to the image_labels table on the server"></span>
</header>

<div class="tab-strip" id="tabStrip">
  <button data-label="" class="active">all</button>
  <button data-label="mask_blur_unusable">blur_unusable</button>
  <button data-label="mask_blur_usable">blur_usable</button>
  <button data-label="mask_bad-photo-quality">bad_photo_quality</button>
  <button data-label="mask_poor-contrast">poor_contrast</button>
  <label id="hideConfidentWrap" style="display:none;margin-left:12px;font-size:12px;color:#aaa;cursor:pointer;font-family:'JetBrains Mono',monospace;">
    <input type="checkbox" id="hideConfident" style="vertical-align:middle;margin-right:4px"> hide confident
    <span style="color:#666">(|p−0.5|&gt;0.4)</span>
  </label>
  <label style="margin-left:12px;font-size:12px;color:#aaa;cursor:pointer;font-family:'JetBrains Mono',monospace;">
    <input type="checkbox" id="hideReviewed" style="vertical-align:middle;margin-right:4px"> hide reviewed
  </label>
  <label style="margin-left:12px;font-size:12px;color:#aaa;cursor:pointer;font-family:'JetBrains Mono',monospace;">
    <input type="checkbox" id="showUnsure" style="vertical-align:middle;margin-right:4px"> show unsure
  </label>
  <label style="margin-left:12px;font-size:12px;color:#aaa;cursor:pointer;font-family:'JetBrains Mono',monospace;">
    <input type="checkbox" id="showTooSmall" style="vertical-align:middle;margin-right:4px"> show too-small
  </label>
  <button id="snapshotMoreBtn" style="display:none;margin-left:4px;font-size:11px;padding:1px 6px" title="Add newly-reviewed cards to the hidden set">↻ hide <span id="snapshotMoreCount">0</span> more</button>
  <button id="showHiddenBtn" style="display:none;margin-left:4px;font-size:11px;padding:1px 6px" title="Clear the snapshot — formerly-hidden cards reappear">show <span id="showHiddenCount">0</span> hidden</button>
  <button id="retrainBtn" style="margin-left:auto;background:#ef4444;color:#fff;border-color:#ef4444;display:none">retrain selected</button>
</div>

<!-- Tab-specific controls: tri-state sort + probability range. Visible only
     when a label tab is active. Sort buttons cycle off → asc → desc → off;
     only one is in a non-off state at any time. Range filter restricts the
     visible set to cards whose predicted_p falls within [min, max]. -->
<div class="tab-controls" id="tabControls">
  <div class="group">
    <span class="label">sort:</span>
    <button class="sort-btn" id="sortProbBtn" data-criterion="prob" data-state="off"
            title="Tri-state: off → low p first → high p first">prob ↕</button>
    <button class="sort-btn" id="sortUncBtn" data-criterion="uncertainty" data-state="off"
            title="Tri-state: off → most uncertain first → most confident first">uncertainty ↕</button>
  </div>
  <div class="group prob-range">
    <span class="label">range:</span>
    <span class="value" id="probMinLabel">0.00</span>
    <input type="range" id="probMin" min="0" max="100" step="1" value="0">
    <input type="range" id="probMax" min="0" max="100" step="1" value="100">
    <span class="value" id="probMaxLabel">1.00</span>
    <button class="range-reset" id="probRangeReset" title="Reset to [0.00, 1.00]">reset</button>
  </div>
</div>

<div class="help">
  <b>4-column label vocabulary:</b>
  <span style="color:#4ac64a">Col 1 BBox:</span> Did the detector pick the right region? ·
  <span style="color:#f59e0b">Col 2 BBox Content:</span> What is inside the bbox? ·
  <span style="color:#67D4E6">Col 3 Mask Rule:</span> Mask-derived quality ·
  <span style="color:#FF6EC7">Col 4 ML Label:</span> Catch-all
  <br><b>Pre-active defaults</b> (no clicks for typical cards): col1 <code>correct-not-clipped</code> + col2 <code>single</code> for has-bbox; col2 <code>no-bug</code> for no-bbox. Click only to override; click an active button to clear it. <b>Rule hint</b> (<code>rule says: …</code>) is informational — sam3-miscalibrated, verify with bug-zoom.
  <br><span style="color:#666"><b>C</b> commits the displayed defaults for the next unreviewed card — left-hand key so your right hand stays on the mouse. Hover any image to zoom. Every click writes to <code>image_labels</code> (SQLite).</span>
</div>

<div class="grid" id="grid"></div>

<script>
const DATA = {{ data_json }};

// 4-column label vocabulary (Phase 2a)
const COL1_BUTTONS = [
  { id: "bbox_correct-subject_not-clipped", label: "Correct\u00a0Not\u00a0Clipped", tip: "Bbox on right bug, full body. DEFAULT \u2014 gate-pass." },
  { id: "bbox_correct-subject_clipped",     label: "Correct\u00a0Clipped",          tip: "Right bug but body cut off by frame or bbox edge." },
  { id: "bbox_wrong-subject",               label: "Wrong\u00a0Subject",            tip: "Bbox EXISTS but is on the wrong thing (flower, leaf, different bug)." },
  { id: "bbox_should-have-bbox",            label: "Should\u00a0Have\u00a0Bbox",    tip: "No bbox but a bug IS visible \u2014 detector missed it. For recall metrics." },
];
const COL2_COUNT_BUTTONS = [
  { id: "bbox-content_single",                  label: "Single",              tip: "One bug inside bbox. DEFAULT." },
  { id: "bbox-content_no-bug",                  label: "No\u00a0Bug",         tip: "No insect in bbox at all." },
  { id: "bbox-content_bbox-multibug_unusable",  label: "Multibug\u00a0Unusable", tip: ">=2 bug centers inside bbox \u2014 system auto-set." },
  { id: "bbox-content_bbox-multibug_usable",    label: "Multibug\u00a0Usable",   tip: ">=2 bugs but still drawable (human override)." },
];
const COL2_FLAG_BUTTONS = [
  { id: "bbox-content_subject-too-small",   label: "Too\u00a0Small",            tip: "Bug bbox long-edge < 512px.", informational: false },
  { id: "bbox-content_partially-concealed", label: "Partially\u00a0Concealed",  tip: "Bug visible but partly hidden (leaf, branch, debris).", informational: false },
  { id: "bbox-content_image-multi-bug",     label: "Image\u00a0Multi",          tip: ">=2 distinct detections in image \u2014 informational, not a gate signal.", informational: true },
];
const COL3_BUTTONS = [
  { id: "mask_poor-contrast",     label: "Poor\u00a0Contrast",     tip: "Bug nearly indistinguishable from background." },
  { id: "mask_blur_unusable",     label: "Blur\u00a0Unusable",     tip: "Subject too blurred to draw. Mutex with Blur Usable." },
  { id: "mask_blur_usable",       label: "Blur\u00a0Usable",       tip: "Some blur, still drawable. Mutex with Blur Unusable." },
  { id: "mask_bad-photo-quality", label: "Bad\u00a0Photo\u00a0Quality", tip: "Subject is sharp but photo is grainy / noisy / poor color (bad camera). Drawable in principle but renders poorly." },
];
const COL4_BUTTONS = [
  { id: "ml_other-bad", label: "Other\u00a0Bad", tip: "Bad for drawing for some other reason." },
];
const COL2_COUNT_IDS = new Set(COL2_COUNT_BUTTONS.map(b => b.id));
const COL3_BLUR_MUTEX = ["mask_blur_unusable", "mask_blur_usable"];
const NEGATIVE_CLASSES = new Set(["flower", "leaf", "stem", "rock"]);

// Variants pre-dating the {detector}__{segmenter} convention had no variant_tag in labels.json; assume the legacy default.
const IMPLICIT_VARIANT = "grounding_dino__insectsam";
// How many secondary detections to summarize below the images before collapsing to "+ N more".
const MAX_SECONDARY = 2;
// Padding ratio applied around the primary bbox for the bug-zoom view AND for the dashed yellow viewport indicator on the original image. These must match.
const BUG_ZOOM_PAD = 0.3;

// Source of truth: server-owned `image_labels` SQLite table. We mirror it
// in-memory here; every mutation POSTs the full dict back. localStorage
// is no longer used — origin / port changes don't lose work anymore.
let LABELS = {};
let savePending = 0;

// SAM 3 mask outlines (yellow polygon overlay on bug-zoom). Loaded once
// at startup from tools/validator/sam3_mask_contours.json — pre-computed
// by scripts/compute_sam3_mask_contours.py. {image_id: [[x,y], ...]}
// in normalized [0,1] coords. Missing image_ids render no overlay.
let MASK_CONTOURS = {};

// Per-label ML metrics: {label: {n_total, n_positives, arm_scalar: {mcc_mean, ...}}}
// Loaded from scripts/detect_subjects/ml_labeler/models/<label>/metrics.json at startup.
// Used to render tab labels with positive counts + current MCC so the user can
// see at a glance where their labeling effort has the most leverage.
let ML_METRICS = {};
const TIER1_LABELS = [
  "mask_blur_unusable",
  "mask_blur_usable",
  "mask_bad-photo-quality",
  "mask_poor-contrast",
];
async function loadMLMetrics() {
  await Promise.all(TIER1_LABELS.map(async (label) => {
    try {
      const url = `/scripts/detect_subjects/ml_labeler/models/${label}/metrics.json`;
      const res = await fetch(url, { cache: 'no-store' });
      if (res.ok) ML_METRICS[label] = await res.json();
    } catch (e) { /* missing metrics is fine — tab just shows label name */ }
  }));
}

// Hide-confident toggle: when active label tab is selected, hide cards where
// |predicted_p - 0.5| > 0.4 (model is very confident; relabeling these gives
// little marginal information). Reduces low-leverage labeling cycles.
let hideConfident = false;
let hideReviewed = false;
// Unsure cards are always hidden by default (they're "set aside"). Toggle
// `showUnsure` to bring them back into the visible set (e.g., to revisit).
// Use the Status=unsure filter to see ONLY unsure cards.
let showUnsure = false;
// too_small cards (framing_quality == 'bug_too_small') get filtered out at
// the gallery's drawability gate — students never see them. Labeling them
// is low-value, so hide by default. Toggle to inspect / verify the rule.
let showTooSmall = false;
// Tri-state ML sort. criterion = 'prob' | 'uncertainty' | null. direction =
// 'asc' | 'desc' | null. Only one button is non-off at a time. When set, this
// overrides the dropdown sort. Resets on tab change.
let mlSortState = { criterion: null, direction: null };
// Probability range filter — applies only when a tab is active. Cards whose
// predicted_p for the active label falls outside this range are hidden.
// [0, 1] = no filter. Resets on tab change.
let probRange = [0, 1];
// Snapshot of image_ids hidden by hide-reviewed. Snapshot is taken on toggle
// ON and explicit refresh. Live edits (corrections that mark reviewed_at) do
// NOT auto-add to the snapshot — so the card the user just corrected stays
// visible, preventing the "card I just labeled disappeared" UX.
let hiddenIds = new Set();
// Predicate is |predicted_p - 0.5| > 0.4 → cards with p > 0.9 (confidently
// positive) or p < 0.1 (confidently negative) get hidden. Keeps the
// borderline cards (0.1 ≤ p ≤ 0.9) which give the most active-learning
// signal.
const HIDE_CONFIDENT_THRESHOLD = 0.4;

// Render tab strip labels with live counts. Called from render() so they
// stay current as the user labels.
function _refreshTabStrip() {
  // Count unreviewed sam3 cards per tier-1 label, and overall totals.
  const totalCards = DATA.length;
  const tabStrip = document.getElementById('tabStrip');
  const allBtn = tabStrip.querySelector('button[data-label=""]');
  if (allBtn) allBtn.textContent = `all (${totalCards})`;
  for (const label of TIER1_LABELS) {
    const btn = tabStrip.querySelector(`button[data-label="${label}"]`);
    if (!btn) continue;
    const probKey = `predicted_${label}_p`;
    let unreviewed = 0, unsure = 0;
    for (const r of DATA) {
      // Mirror the visible set: don't count too_small (hidden by default) in
      // the per-tab unreviewed count, or the user sees "Nu" but no cards.
      if (!showTooSmall && r.framing_quality === "bug_too_small") continue;
      const lbl = LABELS[r.image_id];
      const isReviewed = lbl && lbl.reviewed_at;
      const isUnsure = lbl && lbl.unsure;
      const hasPrediction = r[probKey] != null && !Number.isNaN(r[probKey]);
      if (!hasPrediction) continue;
      if (!isReviewed) unreviewed++;
      if (isUnsure) unsure++;
    }
    const unsureFrag = unsure > 0 ? ` · ${unsure}?` : '';
    const m = ML_METRICS[label];
    if (m && m.arm_scalar) {
      const mcc = m.arm_scalar.mcc_mean;
      const npos = m.n_positives;
      btn.textContent = `${label.replace(/^mask_|^bbox-content_|^bbox_/, '')} (${unreviewed}u${unsureFrag} · ${npos}p · MCC ${mcc.toFixed(2)})`;
    } else {
      btn.textContent = `${label.replace(/^mask_|^bbox-content_|^bbox_/, '')} (${unreviewed}u${unsureFrag})`;
    }
  }
}
// Active label tab — null shows all cards; otherwise filters + sorts by
// uncertainty (|predicted_p - 0.5| ascending = most-uncertain first).
let activeLabel = null;
async function loadMaskContours() {
  try {
    const res = await fetch('./sam3_mask_contours.json', { cache: 'no-store' });
    if (res.ok) MASK_CONTOURS = await res.json();
  } catch (e) { /* mask overlay is optional — silent failure */ }
}

function _emptyLabel() {
  return { col1: null, col2_count: null, col2_flags: [], col3: [], col4: [],
           unsure: false, reviewed_at: null, user_edited: false, variant_tag: null };
}

// Smart defaults: typical cards commit with zero clicks. has-bbox -> col1=
// correct-not-clipped, col2=single. no-bbox -> col2=no-bug. Rule_labeler
// suggestions for col2_flags/col3/col4 are pre-selected too — user trusts
// the threshold thresholds enough to override only the misses (validated:
// "I'm just going to fully label the first 100").
function _hasBbox(r) { return !!(r && r.bbox_x !== null && r.bbox_x !== undefined); }
function _defaultCol1(r) { return _hasBbox(r) ? "bbox_correct-subject_not-clipped" : null; }
function _defaultCol2Count(r) { return _hasBbox(r) ? "bbox-content_single" : "bbox-content_no-bug"; }

function _ruleSuggested(r, idSet) {
  const sugg = r.suggested_labels || [];
  return sugg.filter(s => idSet.has(s));
}
function _firstRuleSuggested(r, idSet) {
  const sugg = r.suggested_labels || [];
  for (const s of sugg) if (idSet.has(s)) return s;
  return null;
}

// Display value for buttons: shows default-as-active until the user touches
// anything on this card. After user_edited, only the stored value shows.
// For single-select cols (col1, col2_count) rule suggestion overrides default.
// For multi-select cols (col2_flags, col3, col4) we union stored + suggestion.
function _displayCol1(r, lbl) {
  if (lbl.user_edited) return lbl.col1;
  if (lbl.col1) return lbl.col1;
  const col1Ids = new Set(COL1_BUTTONS.map(b => b.id));
  return _firstRuleSuggested(r, col1Ids) || _defaultCol1(r);
}
function _displayCol2Count(r, lbl) {
  if (lbl.user_edited) return lbl.col2_count;
  if (lbl.col2_count) return lbl.col2_count;
  const countIds = new Set(COL2_COUNT_BUTTONS.map(b => b.id));
  return _firstRuleSuggested(r, countIds) || _defaultCol2Count(r);
}
function _displayCol2Flags(r, lbl) {
  if (lbl.user_edited) return lbl.col2_flags || [];
  const ids = new Set(COL2_FLAG_BUTTONS.map(b => b.id));
  return Array.from(new Set([...(lbl.col2_flags || []), ..._ruleSuggested(r, ids)]));
}
function _displayCol3(r, lbl) {
  if (lbl.user_edited) return lbl.col3 || [];
  const ids = new Set(COL3_BUTTONS.map(b => b.id));
  return Array.from(new Set([...(lbl.col3 || []), ..._ruleSuggested(r, ids)]));
}
function _displayCol4(r, lbl) {
  if (lbl.user_edited) return lbl.col4 || [];
  const ids = new Set(COL4_BUTTONS.map(b => b.id));
  return Array.from(new Set([...(lbl.col4 || []), ..._ruleSuggested(r, ids)]));
}

// Convert ALL displayed defaults+rule-suggestions into the actual record.
// MUST be called before flipping user_edited, so the visual state persists.
// Fixes: clicking col1 used to wipe col2's visual "single" default because
// user_edited switched _displayCol2Count from default-branch to stored-branch.
function _materializeAllDefaults(cur, r) {
  if (cur.col1 === null) cur.col1 = _displayCol1(r, cur);
  if (cur.col2_count === null) cur.col2_count = _displayCol2Count(r, cur);
  cur.col2_flags = _displayCol2Flags(r, cur);
  cur.col3 = _displayCol3(r, cur);
  cur.col4 = _displayCol4(r, cur);
}
function notifySaveError(msg) {
  const el = document.getElementById("saveStatus");
  if (el) { el.textContent = "save failed: " + msg; el.style.color = "#ef4444"; }
}

function updateSaveStatus() {
  const el = document.getElementById("saveStatus");
  if (!el) return;
  if (savePending > 0) {
    el.style.color = "#f59e0b";
    el.textContent = "saving" + (savePending > 1 ? " (" + savePending + " queued)" : "") + "…";
    return;
  }
  el.style.color = "#666";
  const n = Object.keys(LABELS).length;
  const reviewed = Object.values(LABELS).filter(v => !!v.reviewed_at).length;
  el.textContent = reviewed + " reviewed · " + n + " labelled";
}

async function loadLabelsFromServer() {
  try {
    const res = await fetch("/api/labels", { cache: "no-store" });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if (data && typeof data === "object") LABELS = data;
  } catch (e) {
    notifySaveError("load: " + e.message);
  }
}

// Pull fresh predicted_*_p / _unreliable values from the server and merge
// into DATA in place. The HTML embeds predictions at build time, which goes
// stale the moment predict.py runs again. Fetching here means a retrain
// + repredict shows up on the next page refresh without a build_html.
async function loadPredictionsFromServer() {
  try {
    const res = await fetch("/api/predictions", { cache: "no-store" });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const preds = await res.json();
    if (!preds || typeof preds !== "object") return;
    let touched = 0;
    for (const row of DATA) {
      const fresh = preds[row.image_id];
      if (!fresh) continue;
      for (const [k, v] of Object.entries(fresh)) {
        if (row[k] !== v) { row[k] = v; touched++; }
      }
    }
    if (touched > 0) console.log(`[predictions] merged ${touched} fresh values from /api/predictions`);
  } catch (e) {
    // Non-fatal — fall back to whatever was baked into the HTML
    console.warn("[predictions] fetch failed, using HTML-embedded values:", e.message);
  }
}

// Coalesce concurrent saves: while one POST is in flight, new mutations
// just queue a re-send when it returns. This keeps the file write rate
// at one-per-click max even with very fast typing.
let saveQueued = false;
async function saveLabelsToServer() {
  if (savePending > 0) { saveQueued = true; return; }
  savePending++;
  updateSaveStatus();
  while (true) {
    saveQueued = false;
    try {
      const res = await fetch("/api/labels", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(LABELS),
      });
      if (!res.ok) throw new Error("HTTP " + res.status + " " + await res.text());
    } catch (e) {
      notifySaveError("save: " + e.message);
      break;
    }
    if (!saveQueued) break;  // nothing new while we were saving — done
  }
  savePending--;
  updateSaveStatus();
}

// Mark the record as user-edited on first interaction. Rule-suggested
// labels are NOT pre-filled — the sam3 rule_labeler is miscalibrated
// (no-bug over-fires 33vs2, multibug_unusable 54vs0, mask_poor-contrast
// 18vs15 w/ only 3 agreeing) and silently endorsing them would
// contaminate the very ground truth needed to re-tune the rule.
// Re-enable pre-fill after threshold sweep produces sam3-tuned values.
function _ensureMaterialized(cur, r) {
  if (cur.user_edited) return;
  cur.user_edited = true;
}

function _rowFor(id) {
  for (const r of DATA) if (r.image_id === id) return r;
  return { suggested_labels: [], variant: null };
}

function _persist(id, cur) {
  cur.reviewed_at = Date.now();
  cur.variant_tag = (_rowFor(id).variant) || "grounding_dino__insectsam";
  if (!cur.user_edited && !cur.col1 && !cur.col2_count &&
      cur.col2_flags.length === 0 && cur.col3.length === 0 &&
      cur.col4.length === 0 && !cur.unsure) {
    delete LABELS[id];
  } else {
    LABELS[id] = cur;
  }
  render();
  saveLabelsToServer();
}

// Single-select setters: clicking an already-active button KEEPS the value
// (col1 and col2_count are mutex — must always have a choice when interacted)
// AND acts as a "confirm + mark reviewed" shortcut so the user doesn't have to
// move the mouse all the way to the reviewed button. To CLEAR these cols, use
// the "? unsure" button which resets all values.
function setCol1(id, btnId) {
  const cur = LABELS[id] || _emptyLabel();
  const r = _rowFor(id);
  if (!cur.user_edited) _materializeAllDefaults(cur, r);
  _ensureMaterialized(cur, r);
  cur.col1 = btnId;
  cur.unsure = false;
  _persist(id, cur);
}
function setCol2Count(id, btnId) {
  const cur = LABELS[id] || _emptyLabel();
  const r = _rowFor(id);
  if (!cur.user_edited) _materializeAllDefaults(cur, r);
  _ensureMaterialized(cur, r);
  cur.col2_count = btnId;
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol2Flag(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  const r = _rowFor(id);
  if (!cur.user_edited) _materializeAllDefaults(cur, r);
  _ensureMaterialized(cur, r);
  if (!Array.isArray(cur.col2_flags)) cur.col2_flags = [];
  const i = cur.col2_flags.indexOf(flagId);
  if (i >= 0) cur.col2_flags.splice(i, 1); else cur.col2_flags.push(flagId);
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol3(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  const r = _rowFor(id);
  if (!cur.user_edited) _materializeAllDefaults(cur, r);
  _ensureMaterialized(cur, r);
  if (!Array.isArray(cur.col3)) cur.col3 = [];
  // Toggle-off path: if clicking an already-active button, just remove it.
  // (Previously the BLUR_MUTEX filter ran first and ate the toggle-off —
  // clicking an active blur button looked like remove-all-blur + add-it-back = no-op.)
  if (cur.col3.includes(flagId)) {
    cur.col3 = cur.col3.filter(f => f !== flagId);
  } else {
    // Toggle-on: enforce blur mutex by removing the other blur button first.
    if (COL3_BLUR_MUTEX.includes(flagId))
      cur.col3 = cur.col3.filter(f => !COL3_BLUR_MUTEX.includes(f));
    cur.col3.push(flagId);
  }
  cur.unsure = false;
  _persist(id, cur);
}
function toggleCol4(id, flagId) {
  const cur = LABELS[id] || _emptyLabel();
  const r = _rowFor(id);
  if (!cur.user_edited) _materializeAllDefaults(cur, r);
  _ensureMaterialized(cur, r);
  if (!Array.isArray(cur.col4)) cur.col4 = [];
  const i = cur.col4.indexOf(flagId);
  if (i >= 0) cur.col4.splice(i, 1); else cur.col4.push(flagId);
  cur.unsure = false;
  _persist(id, cur);
}
function setUnsure(id) {
  const cur = LABELS[id] || _emptyLabel();
  cur.user_edited = true;
  cur.unsure = !cur.unsure;
  if (cur.unsure) {
    // "unsure" is a terminal state: clear all label data. _persist will
    // stamp reviewed_at so the card disappears under hide-reviewed.
    // Training skips unsure cards explicitly (see train.py).
    cur.col1 = null; cur.col2_count = null; cur.col2_flags = [];
    cur.col3 = []; cur.col4 = [];
    _persist(id, cur);
    // Unsure cards are always hidden by default (see render filter); no need
    // to touch hiddenIds.
  } else {
    // Toggling unsure OFF resets the card to a pristine, unreviewed state.
    // We bypass _persist (which would re-stamp reviewed_at) and clear the
    // record entirely, then save. Also drop from the hide-reviewed snapshot
    // (the symmetric counterpart of adding it on toggle-ON).
    delete LABELS[id];
    hiddenIds.delete(id);
    render();
    saveLabelsToServer();
  }
}
function markReviewed(id) {
  const cur = LABELS[id] || _emptyLabel();
  if (cur.reviewed_at && cur.user_edited) { delete LABELS[id]; render(); saveLabelsToServer(); return; }
  const r = _rowFor(id);
  _materializeAllDefaults(cur, r);  // write displayed defaults into the record
  _ensureMaterialized(cur, r);
  _persist(id, cur);
}

function fmtPct(n) { return n === null || n === undefined ? "\u2014" : (n * 100).toFixed(1) + "%"; }
function fmtNum(n, d) { return n === null || n === undefined ? "\u2014" : n.toFixed(d); }

// Position the bug-zoom img + bbox overlay using the image's natural pixel
// dimensions (available after onload). Uniform scale = no aspect distortion.
function _positionBugZoom(img) {
  const container = img.parentNode;
  if (!container) return;
  const containerW = container.clientWidth;
  const containerH = container.clientHeight;
  const imgW = img.naturalWidth;
  const imgH = img.naturalHeight;
  if (!imgW || !imgH || !containerW || !containerH) return;

  const hasBbox = img.dataset.bx !== undefined && img.dataset.bx !== "";
  let dispW, dispH, leftPx, topPx;
  if (hasBbox) {
    const bx = parseFloat(img.dataset.bx);
    const by = parseFloat(img.dataset.by);
    const bw = parseFloat(img.dataset.bw);
    const bh = parseFloat(img.dataset.bh);
    const paddedW = Math.min(1, bw * (1 + 2 * BUG_ZOOM_PAD)) * imgW;
    const paddedH = Math.min(1, bh * (1 + 2 * BUG_ZOOM_PAD)) * imgH;
    // Uniform scale so padded region fits in container (contain — no crop of bbox)
    const scale = Math.min(containerW / paddedW, containerH / paddedH);
    dispW = imgW * scale;
    dispH = imgH * scale;
    // Position so bbox center sits at container center
    leftPx = containerW / 2 - (bx + bw / 2) * dispW;
    topPx  = containerH / 2 - (by + bh / 2) * dispH;
  } else {
    // No bbox: fit whole image in the square (contain)
    const scale = Math.min(containerW / imgW, containerH / imgH);
    dispW = imgW * scale;
    dispH = imgH * scale;
    leftPx = (containerW - dispW) / 2;
    topPx  = (containerH - dispH) / 2;
  }

  img.style.width  = dispW + 'px';
  img.style.height = dispH + 'px';
  img.style.left   = leftPx + 'px';
  img.style.top    = topPx + 'px';

  // Sync the pink bbox overlay rectangle to the displayed image
  const box = container.querySelector('.bug-zoom-box');
  if (box && hasBbox) {
    const bx = parseFloat(img.dataset.bx);
    const by = parseFloat(img.dataset.by);
    const bw = parseFloat(img.dataset.bw);
    const bh = parseFloat(img.dataset.bh);
    box.style.left   = (leftPx + bx * dispW) + 'px';
    box.style.top    = (topPx + by * dispH) + 'px';
    box.style.width  = (bw * dispW) + 'px';
    box.style.height = (bh * dispH) + 'px';
  }

  // Sync the SAM 3 mask outline SVG to the displayed image (viewBox is 0,0,1,1
  // in normalized image coords; positioning the SVG over the img makes it
  // align without any per-point transform).
  const svgOverlay = container.querySelector('.bug-zoom-mask-overlay');
  if (svgOverlay) {
    svgOverlay.style.left   = leftPx + 'px';
    svgOverlay.style.top    = topPx + 'px';
    svgOverlay.style.width  = dispW + 'px';
    svgOverlay.style.height = dispH + 'px';
  }
}

// Per-bbox phrase helpers
function _isNegativePhrase(phrase) {
  if (!phrase) return false;
  const s = phrase.startsWith("a ") ? phrase.slice(2) : phrase.startsWith("an ") ? phrase.slice(3) : phrase;
  return NEGATIVE_CLASSES.has(s.toLowerCase());
}
// Phrase summary as a tight list (max 3 items) below the images. Multi-phrase
// detector prompts get truncated to first segment so "an insect. a butterfly.
// a moth..." renders as "an insect".
function _shortenPhrase(phrase) {
  if (!phrase) return '';
  const dot = phrase.indexOf('.');
  return dot > 0 ? phrase.slice(0, dot) : phrase;
}
function _phraseSummaryHTML(primaryPhrase, primaryConf, secPhrases, secBboxes) {
  const items = [];
  if (primaryPhrase || primaryConf != null) {
    const txt = [_shortenPhrase(primaryPhrase), primaryConf != null ? primaryConf.toFixed(2) : null].filter(Boolean).join(' \u00b7 ');
    items.push('<li><span style="color:#FF6EC7;font-weight:600">primary</span> ' + txt + '</li>');
  }
  let shown = 0;
  for (let i = 0; i < secBboxes.length && shown < MAX_SECONDARY; i++) {
    const phrase = secPhrases[i] || null;
    const conf = (secBboxes[i].length >= 5 && secBboxes[i][4] != null) ? secBboxes[i][4] : null;
    if (!phrase && conf == null) continue;
    const txt = [_shortenPhrase(phrase), conf != null ? conf.toFixed(2) : null].filter(Boolean).join(' \u00b7 ');
    items.push('<li><span style="color:#67D4E6;font-weight:600">secondary</span> ' + txt + '</li>');
    shown++;
  }
  const more = secBboxes.length - shown;
  if (more > 0) {
    items.push('<li style="color:#666">+ ' + more + ' more</li>');
  }
  return items.length ? '<ul class="phrase-summary">' + items.join('') + '</ul>' : '';
}

function render() {
  // Keep hide-reviewed snapshot UI in sync with current LABELS state.
  if (typeof _refreshHideReviewedButtons === 'function') _refreshHideReviewedButtons();
  const sf = document.getElementById("source").value;
  const qf = document.getElementById("quality").value;
  const rf = document.getElementById("reviewStatus").value;
  const sortBy = document.getElementById("sort").value;
  const labels = LABELS;
  let rows = DATA.filter(r => sf === "all" || r.source === sf);
  rows = rows.filter(r => qf === "all" || r.framing_quality === qf);
  // Hide-confident filter — only applies when a label tab is active.
  // Drops cards where the model is very confident either way; keeps the
  // borderline cards that yield the most labeling signal.
  if (activeLabel && hideConfident) {
    const probKey = "predicted_" + activeLabel + "_p";
    rows = rows.filter(r => {
      const p = r[probKey];
      if (p == null) return true;  // keep cards w/o prediction yet
      return Math.abs(p - 0.5) <= HIDE_CONFIDENT_THRESHOLD;
    });
  }
  // Hide-reviewed filter — uses a snapshot of reviewed image_ids taken at
  // toggle/refresh time, NOT live reviewed_at. This way, when the user
  // corrects a card (which auto-marks it reviewed via _persist), the card
  // stays visible until the user explicitly clicks "↻ hide N more".
  if (hideReviewed && hiddenIds.size > 0) {
    rows = rows.filter(r => !hiddenIds.has(r.image_id));
  }
  // Unsure cards are hidden by default unless explicitly shown OR the user
  // filters specifically to unsure via the Status dropdown.
  if (!showUnsure && rf !== "unsure") {
    rows = rows.filter(r => {
      const lbl = labels[r.image_id];
      return !(lbl && lbl.unsure);
    });
  }
  // too_small cards are hidden by default — they never reach the gallery
  // since the drawability gate rejects them. Hiding focuses labeling effort
  // on cards the student will actually see.
  if (!showTooSmall) {
    rows = rows.filter(r => r.framing_quality !== "bug_too_small");
  }
  // On a tab view, hide cards with no predicted_p for the active label.
  // These are no_bug / no-bbox cards where the model can't predict anything
  // meaningful — labeling blur/contrast on a non-existent subject makes no
  // sense, and they otherwise pollute the uncertainty sort (predicted p=0
  // → max distance from 0.5 → sorts first under "uncertainty desc").
  if (activeLabel) {
    const probKey = "predicted_" + activeLabel + "_p";
    rows = rows.filter(r => {
      const p = r[probKey];
      return p != null && !Number.isNaN(p);
    });
  }
  if (rf !== "all") {
    rows = rows.filter(r => {
      const lbl = labels[r.image_id];
      if (rf === "unreviewed") return !lbl || !lbl.reviewed_at;
      if (rf === "reviewed")   return lbl && lbl.reviewed_at && !lbl.unsure;
      if (rf === "unsure")     return lbl && lbl.unsure;
      if (rf === "flagged")    return lbl && (
        lbl.col1 || lbl.col2_count ||
        (lbl.col2_flags && lbl.col2_flags.length > 0) ||
        (lbl.col3 && lbl.col3.length > 0) ||
        (lbl.col4 && lbl.col4.length > 0)
      );
      return true;
    });
  }
  // Probability range filter — applies only when a tab is active. Cards
  // whose predicted_p falls outside the range are hidden. Cards without a
  // prediction are kept (they're not in the model's universe).
  if (activeLabel && (probRange[0] > 0 || probRange[1] < 1)) {
    const probKey = "predicted_" + activeLabel + "_p";
    rows = rows.filter(r => {
      const p = r[probKey];
      if (p == null) return true;
      return p >= probRange[0] && p <= probRange[1];
    });
  }
  // ML sort buttons override dropdown when active. Tracks the active tab.
  // Tiebreakers (so equal-p cards don't shuffle randomly):
  //   prob asc/desc: secondary by detector confidence desc (stable signal)
  //   uncertainty asc: tiebreak by detector confidence desc
  //   uncertainty desc: tiebreak by detector confidence desc
  if (activeLabel && mlSortState.criterion) {
    const probKey = "predicted_" + activeLabel + "_p";
    const dir = mlSortState.direction === 'asc' ? 1 : -1;
    if (mlSortState.criterion === 'prob') {
      rows.sort((a, b) => {
        const diff = dir * ((a[probKey] ?? 0.5) - (b[probKey] ?? 0.5));
        if (diff !== 0) return diff;
        return (b.confidence ?? 0) - (a.confidence ?? 0);
      });
    } else if (mlSortState.criterion === 'uncertainty') {
      rows.sort((a, b) => {
        const da = Math.abs((a[probKey] ?? 0.5) - 0.5);
        const db = Math.abs((b[probKey] ?? 0.5) - 0.5);
        const diff = dir * (da - db);
        if (diff !== 0) return diff;
        return (b.confidence ?? 0) - (a.confidence ?? 0);
      });
    }
  } else if (sortBy === "random") rows.sort(() => Math.random() - 0.5);
  else if (sortBy === "bbox_area") rows.sort((a, b) => (a.bbox_area_ratio ?? 0) - (b.bbox_area_ratio ?? 0));
  else if (sortBy === "bbox_long_edge") rows.sort((a, b) => (a.bbox_long_edge_px ?? 0) - (b.bbox_long_edge_px ?? 0));
  else if (sortBy === "bbox_min_edge") rows.sort((a, b) => (a.bbox_min_edge_px ?? 0) - (b.bbox_min_edge_px ?? 0));
  else if (sortBy === "confidence") rows.sort((a, b) => (a.confidence ?? 0) - (b.confidence ?? 0));
  else if (sortBy === "lab_delta_e") rows.sort((a, b) => (a.lab_delta_e ?? 999) - (b.lab_delta_e ?? 999));
  else if (sortBy === "subject_sharpness") rows.sort((a, b) => (a.subject_sharpness ?? 1e9) - (b.subject_sharpness ?? 1e9));

  document.getElementById("totals").textContent = rows.length + " of " + DATA.length + " images";
  _refreshTabStrip();
  const grid = document.getElementById("grid");
  grid.innerHTML = "";

  for (const r of rows) {
    const lbl = labels[r.image_id] || _emptyLabel();
    const reviewed = !!lbl.reviewed_at;
    const hasAnyFlag = !!(lbl.col1 || lbl.col2_count ||
      (lbl.col2_flags && lbl.col2_flags.length > 0) ||
      (lbl.col3 && lbl.col3.length > 0) ||
      (lbl.col4 && lbl.col4.length > 0));
    const div = document.createElement("div");
    div.className = "card" + (reviewed ? " reviewed" : "") + (hasAnyFlag ? " flagged" : "") + (lbl.unsure ? " unsure" : "");
    div.dataset.imageId = r.image_id;

    // Stale-label warning
    const rowVariant = r.variant || IMPLICIT_VARIANT;
    const lblVariant = lbl.variant_tag || IMPLICIT_VARIANT;
    const isStale = !!(lbl.reviewed_at && lblVariant !== rowVariant);
    const staleHTML = isStale
      ? '<div class="stale-warning visible">\u26a0 Label set against variant <b>' + lblVariant + '</b>; current is <b>' + rowVariant + '</b> \u2014 re-review recommended.</div>'
      : '<div class="stale-warning"></div>';

    // Build primary bbox — no inline label (caused truncation + concealed subject);
    // phrase/conf info lives in the phrase-summary line below the images instead.
    const primaryPhrase = r.text_label || null;
    const primaryConf = r.text_label_score != null ? r.text_label_score : null;
    const primaryNegCls = _isNegativePhrase(primaryPhrase) ? " box-negative" : "";
    const primaryBoxHTML = r.bbox_x !== null
      ? '<div class="box' + primaryNegCls + '" style="left:' + (r.bbox_x*100) + '%;top:' + (r.bbox_y*100) + '%;width:' + (r.bbox_w*100) + '%;height:' + (r.bbox_h*100) + '%"></div>'
      : '';

    const secPhrases = r.secondary_phrases || [];
    const secBboxes = r.secondary_bboxes || [];
    const secondaryBoxHTML = secBboxes.map((b, i) => {
      const phrase = secPhrases[i] || null;
      const negCls = _isNegativePhrase(phrase) ? " box-negative" : "";
      return '<div class="box-secondary' + negCls + '" style="left:' + (b[0]*100) + '%;top:' + (b[1]*100) + '%;width:' + (b[2]*100) + '%;height:' + (b[3]*100) + '%"></div>';
    }).join('');

    // Viewport indicator: dashed rectangle on LEFT image at the same padded-bbox
    // region that the RIGHT bug-zoom is magnifying. Gives the user a clear "the
    // right panel is showing THIS region" cue (especially for tiny bboxes that
    // get 10x+ zoom and look unrelated to the leafy thumbnail).
    let viewportHTML = '';
    if (r.bbox_x !== null) {
      const pbw = Math.min(1, r.bbox_w * (1 + 2 * BUG_ZOOM_PAD));
      const pbh = Math.min(1, r.bbox_h * (1 + 2 * BUG_ZOOM_PAD));
      const pbx = Math.max(0, Math.min(1 - pbw, r.bbox_x - r.bbox_w * BUG_ZOOM_PAD));
      const pby = Math.max(0, Math.min(1 - pbh, r.bbox_y - r.bbox_h * BUG_ZOOM_PAD));
      viewportHTML = '<div class="bug-zoom-viewport" style="left:' + (pbx*100) + '%;top:' + (pby*100) + '%;width:' + (pbw*100) + '%;height:' + (pbh*100) + '%"></div>';
    }
    const boxHTML = viewportHTML + primaryBoxHTML + secondaryBoxHTML;
    const phraseSummaryHTML = _phraseSummaryHTML(primaryPhrase, primaryConf, secPhrases, secBboxes);

    // Bug-zoom panel: real <img> inside a 1:1 container. _positionBugZoom runs on
    // img.onload, reads naturalWidth/Height, and sizes the img so the bbox region
    // (with ~30% padding) is centered without aspect distortion. For no-bbox cards,
    // it just contains the full image.
    let bugZoomHTML;
    if (r.bbox_x !== null) {
      // Mask outline overlay (optional — only renders if contour was pre-computed)
      const contour = MASK_CONTOURS[r.image_id];
      const maskSvg = contour && contour.length >= 3
        ? '<svg class="bug-zoom-mask-overlay" viewBox="0 0 1 1" preserveAspectRatio="none">' +
            '<polygon points="' + contour.map(p => p[0] + ',' + p[1]).join(' ') + '" />' +
          '</svg>'
        : '';
      bugZoomHTML =
        '<div class="bug-zoom">' +
          '<img class="bug-zoom-img" src="' + r.original_path + '" ' +
            'data-bx="' + r.bbox_x + '" data-by="' + r.bbox_y + '" ' +
            'data-bw="' + r.bbox_w + '" data-bh="' + r.bbox_h + '" ' +
            'onload="_positionBugZoom(this)">' +
          maskSvg +
          '<div class="bug-zoom-box"></div>' +
        '</div>';
    } else {
      bugZoomHTML =
        '<div class="bug-zoom">' +
          '<img class="bug-zoom-img" src="' + r.original_path + '" ' +
            'onload="_positionBugZoom(this)">' +
          '<div class="bug-zoom-missed">no bbox \u2014 click <b>Should Have Bbox</b> if insect visible, else press C</div>' +
        '</div>';
    }

    // 4-column buttons. When the card has no bbox, the bbox-derived buttons
    // (col1 correct/clipped, col2 single/multibug/too-small, all of col3)
    // don't apply — dim them so the user knows only wrong-subject / no-bug /
    // unsure are meaningful.
    const suggested = r.suggested_labels || [];
    const hasBbox = r.bbox_x !== null;
    // Col1 buttons that ONLY apply when there's no bbox (e.g., "Should Have Bbox")
    const NOBBOX_ONLY_COL1 = new Set(["bbox_should-have-bbox"]);
    // Col2 buttons that remain enabled when there's no bbox
    const NOBBOX_ENABLED_COL2 = new Set(["bbox-content_no-bug"]);

    const col1Display = _displayCol1(r, lbl);
    const col1HTML = COL1_BUTTONS.map(b => {
      // Dim if (no bbox & button assumes a bbox) OR (has bbox & button is no-bbox-only)
      const dim = (!hasBbox && !NOBBOX_ONLY_COL1.has(b.id)) || (hasBbox && NOBBOX_ONLY_COL1.has(b.id));
      const cls = [(col1Display === b.id ? "active" : ""), (dim ? "nobbox-dim" : "")].filter(Boolean).join(' ');
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="setCol1(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col2CountDisplay = _displayCol2Count(r, lbl);
    const col2CountHTML = COL2_COUNT_BUTTONS.map(b => {
      const dim = !hasBbox && !NOBBOX_ENABLED_COL2.has(b.id);
      const cls = [(col2CountDisplay === b.id ? "active" : ""), (dim ? "nobbox-dim" : "")].filter(Boolean).join(' ');
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="setCol2Count(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col2FlagsDisplay = _displayCol2Flags(r, lbl);
    const col2FlagHTML = COL2_FLAG_BUTTONS.map(b => {
      const isAct = col2FlagsDisplay.includes(b.id);
      const dim = !hasBbox;
      const cls = [(isAct ? "active" : ""), (b.informational ? "informational" : ""), (dim ? "nobbox-dim" : "")].filter(Boolean).join(' ');
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol2Flag(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const col3Display = _displayCol3(r, lbl);
    const col3HTML = COL3_BUTTONS.map(b => {
      const isAct = col3Display.includes(b.id);
      const dim = !hasBbox;
      const cls = [(isAct ? "active" : ""), (dim ? "nobbox-dim" : "")].filter(Boolean).join(' ');
      // ML probability chip — show predicted_p next to the button if we have a prediction for this label
      const probKey = "predicted_" + b.id + "_p";
      const p = r[probKey];
      const chip = (p != null)
        ? '<span class="ml-chip" style="background:' + (p > 0.7 ? '#ef4444' : p < 0.3 ? '#4ac64a' : '#f59e0b') + '">p=' + p.toFixed(2) + '</span>'
        : '';
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol3(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + chip + '</button>';
    }).join('');

    const col4Display = _displayCol4(r, lbl);
    const col4HTML = COL4_BUTTONS.map(b => {
      const cls = col4Display.includes(b.id) ? "active" : "";
      return '<button class="' + cls + '" title="' + b.tip + '" onclick="toggleCol4(\'' + r.image_id + '\',\'' + b.id + '\')">' + b.label + '</button>';
    }).join('');

    const suggestedHintHTML = suggested.length
      ? '<div class="rule-hint" title="Rule labeler\'s guess. Currently miscalibrated for sam3 — verify before clicking.">rule says: ' +
        suggested.map(s => '<code>' + s + '</code>').join(' ') +
        '</div>'
      : '<div class="rule-hint rule-hint-empty">rule says: <em>(nothing — clean single-bug card)</em></div>';

    const columnsHTML =
      '<div class="label-columns">' +
        '<div class="col col1"><div class="col-header">BBox</div>' + col1HTML + '</div>' +
        '<div class="col col2"><div class="col-header">BBox Content</div>' + col2CountHTML + col2FlagHTML + '</div>' +
        '<div class="col col3"><div class="col-header">Mask Rule' +
          (r.predicted_mask_blur_unusable_p != null
            ? '<span class="pred-badge' + (r.predicted_mask_blur_unusable_unreliable ? ' unreliable' : '') + '">blur_p=' + r.predicted_mask_blur_unusable_p.toFixed(2) + '</span>'
            : '') +
        '</div>' + col3HTML + '</div>' +
        '<div class="col col4"><div class="col-header">ML Label</div>' + col4HTML + '</div>' +
      '</div>';

    div.innerHTML =
      '<div class="imgs">' +
        '<figure>' +
          '<div class="bbox-overlay"><img src="' + r.original_path + '" alt="">' + boxHTML + '</div>' +
          '<figcaption>original \u00b7 primary <span style="color:#FF6EC7">pink</span>' +
            ((r.secondary_bboxes && r.secondary_bboxes.length) ? ' \u00b7 <span style="color:#67D4E6">cyan</span> = ' + r.secondary_bboxes.length + ' other detection' + (r.secondary_bboxes.length === 1 ? '' : 's') : '') +
          '</figcaption>' +
        '</figure>' +
        '<figure>' + bugZoomHTML + '<figcaption>bug zoom \u00b7 bbox + 30% padding</figcaption></figure>' +
      '</div>' +
      phraseSummaryHTML +
      '<div class="name">' + (r.common_name || r.taxon_species || "?") + ' <code>\u00b7 ' + r.image_id + '</code></div>' +
      '<span class="badge ' + r.framing_quality + '">' + r.framing_quality + '</span>' +
      '<div class="metrics">' +
        'bbox: ' + fmtPct(r.bbox_area_ratio) + ' (' +
          (r.bbox_long_edge_px !== null && r.bbox_long_edge_px !== undefined ? r.bbox_long_edge_px.toFixed(0) + 'px long' : '\u2014') + ' / ' +
          (r.bbox_min_edge_px !== null && r.bbox_min_edge_px !== undefined ? r.bbox_min_edge_px.toFixed(0) + 'px short' : '\u2014') +
        ') \u00b7 crop fills: ' + fmtPct(r.post_crop_subject_area) + '<br>' +
        'conf: ' + fmtNum(r.confidence, 2) + ' \u00b7 \u0394E: ' + fmtNum(r.lab_delta_e, 1) + ' \u00b7 sharpness: ' + fmtNum(r.subject_sharpness, 0) + '<br>' +
        'detected: ' + r.n_distinct_detections + ' bug' + (r.n_distinct_detections === 1 ? '' : 's') +
        (r.bbox_touches_edge ? ' \u00b7 \u26a0 bbox touches frame edge' : '') +
        (r.gt_iou !== null ? ' \u00b7 gt_iou: ' + r.gt_iou.toFixed(2) : '') +
      '</div>' +
      staleHTML +
      suggestedHintHTML +
      columnsHTML +
      '<div class="review-row">' +
        '<button class="mark-reviewed ' + (reviewed ? 'active' : '') + '" onclick="markReviewed(\'' + r.image_id + '\')" title="Confirms the current labels (accepts the system suggestion if you haven\'t changed anything). Any label edit auto-marks reviewed.">' +
          (reviewed ? '\u2713 reviewed' : '\u2713 mark reviewed') +
        '</button>' +
        '<button class="unsure-button ' + (lbl.unsure ? 'active' : '') + '" onclick="setUnsure(\'' + r.image_id + '\')" title="Ambiguous \u2014 come back later">? unsure</button>' +
      '</div>';
    grid.appendChild(div);
  }
}

document.getElementById("source").addEventListener("change", render);
document.getElementById("quality").addEventListener("change", render);
document.getElementById("reviewStatus").addEventListener("change", render);
document.getElementById("sort").addEventListener("change", render);

// Bbox-only mode: C commits the displayed defaults. For has-bbox cards:
// col1=correct-not-clipped, col2=single. For no-bbox: col2=no-bug, col1
// stays null (vocab has no "missed" state). Rule_labeler suggestions for
// cols 2-4 are NOT auto-applied — sam3 miscalibration risk.
function _commitBboxOnly(id) {
  const cur = LABELS[id] ? Object.assign({}, LABELS[id]) : _emptyLabel();
  const r = _rowFor(id);
  _materializeAllDefaults(cur, r);
  if (!Array.isArray(cur.col2_flags)) cur.col2_flags = [];
  if (!Array.isArray(cur.col3)) cur.col3 = [];
  if (!Array.isArray(cur.col4)) cur.col4 = [];
  cur.user_edited = true;
  _persist(id, cur);
}

// Find the topmost unreviewed card that's currently in the viewport — so C
// commits what the user is looking at, not whatever's first in DOM order
// (which is usually off-screen above once they've scrolled).
function _findVisibleTargetCard() {
  const cards = document.querySelectorAll(".card:not(.reviewed)");
  for (const card of cards) {
    const rect = card.getBoundingClientRect();
    if (rect.bottom > 0 && rect.top < window.innerHeight) return card;
  }
  return cards[0] || null;
}

// Lightweight toast confirmation — survives the post-commit re-render so the
// user knows the C actually did something (the committed card vanishes from
// view when filter=unreviewed, which previously looked like nothing happened).
function _toast(msg) {
  let t = document.getElementById('commitToast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'commitToast';
    t.style.cssText = 'position:fixed;top:60px;right:24px;padding:8px 14px;border-radius:6px;font:600 13px/1.2 system-ui,sans-serif;color:#0d0c10;background:#4ac64a;box-shadow:0 4px 16px rgba(0,0,0,0.6);z-index:200;transition:opacity 0.2s;opacity:0;pointer-events:none;max-width:360px;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.style.opacity = '0'; }, 1400);
}

document.addEventListener("keydown", function(e) {
  if (e.key !== "c" && e.key !== "C") return;
  if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
  const card = _findVisibleTargetCard();
  if (!card || !card.dataset.imageId) return;
  const id = card.dataset.imageId;
  _commitBboxOnly(id);
  _toast('\u2713 committed ' + id);
  // After re-render, scroll next target into view so the change is obvious.
  requestAnimationFrame(() => {
    const next = _findVisibleTargetCard();
    if (next) next.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
});

// Initial paint with empty LABELS + empty MASK_CONTOURS so the grid is up
// immediately; then fetch both in parallel and re-render. Mask contours
// rendering is independent of label data — both refresh on arrival.
render();
updateSaveStatus();
Promise.all([
  loadLabelsFromServer(),
  loadMaskContours(),
  loadMLMetrics(),
  loadPredictionsFromServer(),
]).then(() => {
  render();
  updateSaveStatus();
});

document.getElementById('tabStrip').addEventListener('click', (e) => {
  const btn = e.target.closest('button[data-label]');
  if (!btn) return;
  if (btn.id === 'retrainBtn') return;  // handled by separate listener below
  activeLabel = btn.dataset.label || null;
  for (const b of document.querySelectorAll('#tabStrip button')) {
    b.classList.toggle('active', b === btn);
  }
  document.getElementById('retrainBtn').style.display = activeLabel ? 'inline-block' : 'none';
  document.getElementById('hideConfidentWrap').style.display = activeLabel ? 'inline-block' : 'none';
  // Show/hide tab-controls row (sort buttons + prob range slider).
  document.getElementById('tabControls').classList.toggle('visible', !!activeLabel);
  // Reset tab-local sort/filter state when switching tabs — keeps semantics
  // clear ("range I set for label A doesn't carry over to label B").
  mlSortState = { criterion: null, direction: null };
  for (const sb of document.querySelectorAll('#tabControls button.sort-btn')) {
    _setSortBtnState(sb, 'off');
  }
  probRange = [0, 1];
  document.getElementById('probMin').value = 0;
  document.getElementById('probMax').value = 100;
  document.getElementById('probMinLabel').textContent = '0.00';
  document.getElementById('probMaxLabel').textContent = '1.00';
  // Default sort intent for a fresh tab: most uncertain first. Easier than
  // expecting the user to click 3 things to start labeling.
  if (activeLabel) {
    mlSortState = { criterion: 'uncertainty', direction: 'asc' };
    _setSortBtnState(document.getElementById('sortUncBtn'), 'asc');
  }
  render();
});

// Tri-state sort buttons. Cycle: off → asc → desc → off. Only one
// button at a time can be in a non-off state.
const SORT_CYCLE = { off: 'asc', asc: 'desc', desc: 'off' };
const SORT_ICONS = { off: '↕', asc: '↑', desc: '↓' };
function _setSortBtnState(btn, state) {
  btn.dataset.state = state;
  const crit = btn.dataset.criterion;
  btn.textContent = crit + ' ' + SORT_ICONS[state];
}
function _onSortBtnClick(e) {
  const btn = e.currentTarget;
  const next = SORT_CYCLE[btn.dataset.state];
  // Reset siblings to off — single-button-active invariant.
  for (const other of document.querySelectorAll('#tabControls button.sort-btn')) {
    if (other !== btn) _setSortBtnState(other, 'off');
  }
  _setSortBtnState(btn, next);
  mlSortState = next === 'off'
    ? { criterion: null, direction: null }
    : { criterion: btn.dataset.criterion, direction: next };
  render();
}
document.getElementById('sortProbBtn').addEventListener('click', _onSortBtnClick);
document.getElementById('sortUncBtn').addEventListener('click', _onSortBtnClick);

// Probability range slider — two thumbs, mutually constrained.
function _updateProbRangeLabels() {
  document.getElementById('probMinLabel').textContent = probRange[0].toFixed(2);
  document.getElementById('probMaxLabel').textContent = probRange[1].toFixed(2);
}
document.getElementById('probMin').addEventListener('input', (e) => {
  let v = parseInt(e.target.value, 10) / 100;
  if (v > probRange[1]) { v = probRange[1]; e.target.value = String(Math.round(v * 100)); }
  probRange[0] = v;
  _updateProbRangeLabels();
  render();
});
document.getElementById('probMax').addEventListener('input', (e) => {
  let v = parseInt(e.target.value, 10) / 100;
  if (v < probRange[0]) { v = probRange[0]; e.target.value = String(Math.round(v * 100)); }
  probRange[1] = v;
  _updateProbRangeLabels();
  render();
});
document.getElementById('probRangeReset').addEventListener('click', () => {
  probRange = [0, 1];
  document.getElementById('probMin').value = 0;
  document.getElementById('probMax').value = 100;
  _updateProbRangeLabels();
  render();
});

// Hide-confident checkbox handler: re-render to apply/lift the filter.
document.getElementById('hideConfident').addEventListener('change', (e) => {
  hideConfident = e.target.checked;
  render();
});

// Hide-reviewed snapshot helpers. The filter operates on `hiddenIds`, not
// live reviewed_at, so the working set is stable while the user edits.
function _allReviewedIds() {
  const ids = new Set();
  for (const r of DATA) {
    const lbl = LABELS[r.image_id];
    if (lbl && lbl.reviewed_at) ids.add(r.image_id);
  }
  return ids;
}
function _newlyReviewedNotInSnapshot() {
  const out = [];
  for (const r of DATA) {
    const lbl = LABELS[r.image_id];
    if (lbl && lbl.reviewed_at && !hiddenIds.has(r.image_id)) out.push(r.image_id);
  }
  return out;
}
function _refreshHideReviewedButtons() {
  const wrap = document.getElementById('snapshotMoreBtn');
  const showBtn = document.getElementById('showHiddenBtn');
  if (!hideReviewed) {
    wrap.style.display = 'none';
    showBtn.style.display = 'none';
    return;
  }
  const moreIds = _newlyReviewedNotInSnapshot();
  if (moreIds.length > 0) {
    wrap.style.display = 'inline-block';
    document.getElementById('snapshotMoreCount').textContent = moreIds.length;
  } else {
    wrap.style.display = 'none';
  }
  if (hiddenIds.size > 0) {
    showBtn.style.display = 'inline-block';
    document.getElementById('showHiddenCount').textContent = hiddenIds.size;
  } else {
    showBtn.style.display = 'none';
  }
}

document.getElementById('hideReviewed').addEventListener('change', (e) => {
  hideReviewed = e.target.checked;
  if (hideReviewed) {
    hiddenIds = _allReviewedIds();  // initial snapshot
  } else {
    hiddenIds = new Set();
  }
  _refreshHideReviewedButtons();
  render();
});
document.getElementById('showUnsure').addEventListener('change', (e) => {
  showUnsure = e.target.checked;
  render();
});
document.getElementById('showTooSmall').addEventListener('change', (e) => {
  showTooSmall = e.target.checked;
  render();
});
document.getElementById('snapshotMoreBtn').addEventListener('click', () => {
  // Add newly-reviewed cards to the snapshot
  for (const id of _newlyReviewedNotInSnapshot()) hiddenIds.add(id);
  _refreshHideReviewedButtons();
  render();
});
document.getElementById('showHiddenBtn').addEventListener('click', () => {
  // Clear the snapshot — formerly-hidden cards reappear. Checkbox stays
  // checked so the next snapshot starts empty until user clicks "↻ hide N more".
  hiddenIds = new Set();
  _refreshHideReviewedButtons();
  render();
});

document.getElementById('retrainBtn').addEventListener('click', async () => {
  if (!activeLabel) return;
  const btn = document.getElementById('retrainBtn');
  btn.disabled = true;
  btn.textContent = `retraining ${activeLabel}...`;
  try {
    const res = await fetch(`/api/retrain/${activeLabel}`, { method: 'POST' });
    const body = await res.json();
    if (res.ok) {
      btn.textContent = `done — reload page`;
      setTimeout(() => window.location.reload(), 1500);
    } else {
      btn.textContent = `failed: ${body.error || 'unknown'}`;
      btn.disabled = false;
    }
  } catch (e) {
    btn.textContent = `error: ${e.message}`;
    btn.disabled = false;
  }
});

// Mouse-follow zoom popup with bbox-on-original preservation.
const zoomPopup = document.createElement("div");
zoomPopup.id = "zoomPopup";
const zoomImg = document.createElement("img");
const zoomBox = document.createElement("div");
zoomBox.className = "zoom-bbox";
zoomPopup.appendChild(zoomImg);
zoomPopup.appendChild(zoomBox);
document.body.appendChild(zoomPopup);
const ZOOM_MARGIN_VW = 1;
function vwToPx(v) { return v * window.innerWidth / 100; }
// Both LEFT (original) and RIGHT (bug-zoom) images are hoverable.
// Left -> full-original popup with bbox overlays (context shot).
// Right -> 50vw bug-zoom-style popup (detail shot via _positionBugZoom math).
function isZoomTarget(el) {
  return el && el.tagName === "IMG" && el.closest(".imgs figure");
}
function _resetZoomPopup() {
  // Strip any prior bug-zoom-clone or mirrored secondary boxes
  [...zoomPopup.querySelectorAll(".zoom-bbox-secondary, .bug-zoom-clone")].forEach(n => n.remove());
  // Restore the default zoomImg + zoomBox visibility
  zoomImg.style.display = "";
  zoomBox.style.display = "";
}
function _hoverOriginal(target) {
  _resetZoomPopup();
  zoomImg.src = target.src;
  const overlay = target.closest(".bbox-overlay");
  const box = overlay ? overlay.querySelector(".box") : null;
  if (box) {
    zoomBox.style.cssText = "position:absolute;box-sizing:border-box;display:block;" + box.style.cssText;
    zoomBox.style.border = "0.25vw solid #FF6EC7";
  } else {
    zoomBox.style.display = "none";
  }
  if (overlay) {
    for (const sb of overlay.querySelectorAll(".box-secondary")) {
      const mirror = document.createElement("div");
      mirror.className = "zoom-bbox-secondary";
      mirror.style.cssText = sb.style.cssText;
      if (sb.dataset.conf) mirror.dataset.conf = sb.dataset.conf;
      zoomPopup.appendChild(mirror);
    }
  }
  zoomPopup.style.display = "block";
}
function _hoverBugZoom(target) {
  _resetZoomPopup();
  zoomImg.style.display = "none";  // not used in this mode
  zoomBox.style.display = "none";
  const clone = document.createElement("div");
  clone.className = "bug-zoom bug-zoom-clone";
  clone.style.cssText = "width: 50vw; aspect-ratio: 1/1; position: relative; overflow: hidden; background: #0d0c10; border: 0.2vw solid #FF6EC7; border-radius: 0.3vw; box-shadow: 0 1vw 3vw rgba(0,0,0,0.7);";
  const img = document.createElement("img");
  img.className = "bug-zoom-img";
  img.src = target.src;
  if (target.dataset.bx) {
    img.dataset.bx = target.dataset.bx;
    img.dataset.by = target.dataset.by;
    img.dataset.bw = target.dataset.bw;
    img.dataset.bh = target.dataset.bh;
  }
  const box = document.createElement("div");
  box.className = "bug-zoom-box";
  clone.appendChild(img);
  clone.appendChild(box);
  zoomPopup.appendChild(clone);
  zoomPopup.style.display = "block";
  const reposition = () => _positionBugZoom(img);
  if (img.complete && img.naturalWidth > 0) reposition();
  else img.onload = reposition;
}
document.addEventListener("mouseover", (e) => {
  if (!isZoomTarget(e.target)) return;
  if (e.target.closest(".bug-zoom")) _hoverBugZoom(e.target);
  else _hoverOriginal(e.target);
});
document.addEventListener("mouseout", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.style.display = "none";
  _resetZoomPopup();
});
document.addEventListener("mousemove", (e) => {
  if (zoomPopup.style.display !== "block") return;
  const r = zoomPopup.getBoundingClientRect();
  const zw = r.width || vwToPx(50);
  const zh = r.height || vwToPx(50);
  const m = vwToPx(ZOOM_MARGIN_VW);
  let x = e.clientX + m;
  let y = e.clientY + m;
  if (x + zw > window.innerWidth - m) x = e.clientX - zw - m;
  if (y + zh > window.innerHeight - m) y = window.innerHeight - zh - m;
  if (x < m) x = m;
  if (y < m) y = m;
  zoomPopup.style.left = x + "px";
  zoomPopup.style.top = y + "px";
});
</script>
</body>
</html>

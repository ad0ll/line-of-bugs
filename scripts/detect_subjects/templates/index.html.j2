<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Framing Validator · {{ variant }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; background: #16141a; color: #f5f5f5; margin: 0; padding: 0; }
  header { position: sticky; top: 0; background: #0d0c10; padding: 12px 24px; border-bottom: 1px solid #28252e; z-index: 10; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  header h1 { margin: 0; font-size: 18px; color: #FF6EC7; }
  header label { font-size: 13px; color: #aaa; }
  header select { background: #16141a; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 8px; }
  header button { background: #FF6EC7; color: #0d0c10; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
  .totals { margin-left: auto; font-size: 13px; color: #aaa; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; padding: 24px; }
  .card { background: #1a1820; border: 1px solid #28252e; border-radius: 8px; padding: 12px; }
  .imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; align-items: start; }
  .imgs figure { margin: 0; }
  .imgs figcaption { font-size: 11px; color: #888; margin-top: 2px; }
  /* Image fills its container WIDTH and its own natural aspect ratio drives the height.
     bbox-overlay wraps the image so the bbox div positions against the image bounds,
     not a fixed-height letterboxed container. */
  .imgs img { width: 100%; height: auto; background: #0d0c10; border-radius: 4px; display: block; }
  .name { font-size: 14px; margin: 4px 0; color: #f5f5f5; }
  .name code { color: #67D4E6; font-size: 11px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; margin: 4px 0; }
  .badge.good { background: #2d4a2d; color: #a8e6a8; }
  .badge.tight { background: #2d4a2d; color: #a8e6a8; }
  .badge.wide { background: #4a3d2d; color: #e6c8a8; }
  .badge.hidden { background: #4a2d2d; color: #e6a8a8; }
  .badge.multi_bug { background: #4a2d4a; color: #e6a8e6; }
  .badge.camouflaged { background: #2d3a4a; color: #a8c8e6; }
  .metrics { font-size: 12px; color: #aaa; font-family: 'JetBrains Mono', monospace; margin: 4px 0; line-height: 1.5; }
  .labels { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr; gap: 4px; margin-top: 8px; }
  .labels button { padding: 6px 4px; border: 1px solid #444; background: #1a1820; color: #aaa; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: 400; }
  .labels button:hover { color: #f5f5f5; border-color: #666; }
  .labels button.active { background: #FF6EC7; color: #0d0c10; border-color: #FF6EC7; font-weight: 600; }
  .labels button.wrong-bbox.active { background: #ef4444; color: #fff; border-color: #ef4444; }
  .labels button.wrong-class.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; }
  .labels button.wrong-crop.active { background: #A78BFA; color: #0d0c10; border-color: #A78BFA; }
  .bbox-overlay { position: relative; display: block; line-height: 0; }
  .bbox-overlay .box { position: absolute; border: 2px solid #FF6EC7; pointer-events: none; box-sizing: border-box; }
  .nocrop { width: 100%; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; background: #0d0c10; color: #666; font-size: 12px; border-radius: 4px; }
  /* Mouse-follow zoom popup. A single global #zoomPopup is created in JS
     and positioned next to the cursor on mouseover. Capped at 560×560
     with natural aspect ratio preserved. */
  #zoomPopup {
    position: fixed;
    width: auto; height: auto;
    max-width: 38vw; max-height: 70vh;
    object-fit: contain;
    z-index: 1000;
    background: #0d0c10; border: 2px solid #FF6EC7; border-radius: 4px;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.7);
    pointer-events: none;
    display: none;
  }
  /* "Should be" override row */
  .should-be { display: flex; gap: 4px; margin-top: 6px; align-items: center; font-size: 11px; color: #888; }
  .should-be select { flex: 1; background: #1a1820; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 6px; font-size: 11px; cursor: pointer; }
  .should-be select.set { border-color: #f59e0b; color: #f59e0b; }
  /* Help blurb */
  .help { font-size: 12px; color: #aaa; padding: 8px 24px; background: #1a1820; border-bottom: 1px solid #28252e; }
  .help code { background: #0d0c10; padding: 1px 5px; border-radius: 3px; color: #FF6EC7; font-family: 'JetBrains Mono', monospace; }
  .help b { color: #f5f5f5; }
</style>
</head>
<body>
<header>
  <h1>✿ Framing Validator</h1>
  <label>Variant <select id="variant"><option>{{ variant }}</option></select></label>
  <label>Source <select id="source"><option value="all">all</option>{% for s in sources %}<option value="{{ s }}">{{ s }}</option>{% endfor %}</select></label>
  <label>Quality <select id="quality"><option value="all">all</option><option value="good">good</option><option value="tight">tight</option><option value="wide">wide</option><option value="hidden">hidden</option><option value="multi_bug">multi_bug</option><option value="camouflaged">camouflaged</option></select></label>
  <label>Sort <select id="sort"><option value="bbox_area">area ↑</option><option value="confidence">conf ↑</option><option value="lab_delta_e">ΔE ↑</option><option value="random">random</option></select></label>
  <span class="totals" id="totals">{{ total }} images</span>
  <button onclick="exportLabels()">Export labels</button>
</header>

<div class="help">
  <b>Labels:</b>
  <code>✓ correct</code> bbox + class + crop all look right ·
  <code>✗ bbox</code> bbox missed the bug, captured wrong part, or wrong subject ·
  <code>✗ class</code> bbox is fine but the <code>good/wide/hidden/...</code> label is wrong ·
  <code>✗ crop</code> bbox + class fine but crop aesthetic is wrong (too tight, too loose, off-center) ·
  <code>? unsure</code> ambiguous · Hover any image to zoom.
</div>

<div class="grid" id="grid"></div>

<script>
const DATA = {{ data_json }};
const ROOT = "{{ root }}";
const LABEL_KEY = "framing_labels";

function getLabels() {
  const raw = JSON.parse(localStorage.getItem(LABEL_KEY) || "{}");
  // Upgrade old string-only entries into the {status, should_be} shape.
  for (const k of Object.keys(raw)) {
    if (typeof raw[k] === "string") raw[k] = { status: raw[k], should_be: null };
  }
  return raw;
}
function setLabels(o) {
  localStorage.setItem(LABEL_KEY, JSON.stringify(o));
}

// Toggle the status (✓ correct / ✗ bbox / ✗ class / ✗ crop / ? unsure).
function label(id, kind) {
  const all = getLabels();
  const cur = all[id] || { status: null, should_be: null };
  cur.status = cur.status === kind ? null : kind;
  if (cur.status === null && cur.should_be === null) delete all[id];
  else all[id] = cur;
  setLabels(all);
  render();
}

// Set the "should be" override (or clear it if "" is selected).
function setShouldBe(id, value) {
  const all = getLabels();
  const cur = all[id] || { status: null, should_be: null };
  cur.should_be = value || null;
  // Setting should_be implies wrong-class unless already flagged.
  if (cur.should_be && !cur.status) cur.status = "wrong-class";
  if (cur.status === null && cur.should_be === null) delete all[id];
  else all[id] = cur;
  setLabels(all);
  render();
}

function exportLabels() {
  const blob = new Blob([JSON.stringify(getLabels(), null, 2)], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "labels.json";
  a.click();
}

function fmtPct(n) { return n === null || n === undefined ? "—" : (n * 100).toFixed(1) + "%"; }
function fmtNum(n, d) { return n === null || n === undefined ? "—" : n.toFixed(d); }

function render() {
  const sf = document.getElementById("source").value;
  const qf = document.getElementById("quality").value;
  const sortBy = document.getElementById("sort").value;
  const labels = getLabels();
  let rows = DATA.filter(r => sf === "all" || r.source === sf);
  rows = rows.filter(r => qf === "all" || r.framing_quality === qf);
  if (sortBy === "random") rows.sort(() => Math.random() - 0.5);
  else if (sortBy === "bbox_area") rows.sort((a, b) => (a.bbox_area_ratio ?? 0) - (b.bbox_area_ratio ?? 0));
  else if (sortBy === "confidence") rows.sort((a, b) => (a.confidence ?? 0) - (b.confidence ?? 0));
  else if (sortBy === "lab_delta_e") rows.sort((a, b) => (a.lab_delta_e ?? 999) - (b.lab_delta_e ?? 999));
  document.getElementById("totals").textContent = rows.length + " of " + DATA.length + " images";
  const grid = document.getElementById("grid");
  grid.innerHTML = "";
  for (const r of rows) {
    const lblObj = labels[r.image_id] || { status: null, should_be: null };
    const status = lblObj.status;
    const shouldBe = lblObj.should_be;
    const div = document.createElement("div");
    div.className = "card";
    const boxHTML = r.bbox_x !== null
      ? '<div class="box" style="left:' + (r.bbox_x*100) + '%;top:' + (r.bbox_y*100) + '%;width:' + (r.bbox_w*100) + '%;height:' + (r.bbox_h*100) + '%"></div>'
      : '';
    const cropHTML = r.crop_path
      ? '<img src="' + r.crop_path + '" alt="">'
      : '<div class="nocrop">no crop (' + r.framing_quality + ')</div>';
    div.innerHTML =
      '<div class="imgs">' +
        '<figure>' +
          '<div class="bbox-overlay"><img src="' + r.original_path + '" alt="">' + boxHTML + '</div>' +
          '<figcaption>original · bbox shown in pink</figcaption>' +
        '</figure>' +
        '<figure>' + cropHTML + '<figcaption>proposed crop · what users see</figcaption></figure>' +
      '</div>' +
      '<div class="name">' + (r.common_name || r.taxon_species || "?") + ' <code>· ' + r.image_id + '</code></div>' +
      '<span class="badge ' + r.framing_quality + '">' + r.framing_quality + '</span>' +
      '<div class="metrics">' +
        'bbox: ' + fmtPct(r.bbox_area_ratio) + ' → crop: ' + fmtPct(r.post_crop_subject_area) + '<br>' +
        'conf: ' + fmtNum(r.confidence, 2) + ' · ΔE: ' + fmtNum(r.lab_delta_e, 1) + ' · off-center: ' + fmtNum(r.offcenter, 2) + '<br>' +
        'detected: ' + r.n_distinct_detections + ' bug' + (r.n_distinct_detections === 1 ? '' : 's') +
        (r.gt_iou !== null ? ' · gt_iou: ' + r.gt_iou.toFixed(2) : '') +
      '</div>' +
      '<div class="labels">' +
        '<button class="' + (status === 'ok' ? 'active' : '') + '" onclick="label(\'' + r.image_id + '\',\'ok\')">✓ correct</button>' +
        '<button class="wrong-bbox ' + (status === 'wrong-bbox' ? 'active' : '') + '" onclick="label(\'' + r.image_id + '\',\'wrong-bbox\')">✗ bbox</button>' +
        '<button class="wrong-class ' + (status === 'wrong-class' ? 'active' : '') + '" onclick="label(\'' + r.image_id + '\',\'wrong-class\')">✗ class</button>' +
        '<button class="wrong-crop ' + (status === 'wrong-crop' ? 'active' : '') + '" onclick="label(\'' + r.image_id + '\',\'wrong-crop\')">✗ crop</button>' +
        '<button class="' + (status === 'unsure' ? 'active' : '') + '" onclick="label(\'' + r.image_id + '\',\'unsure\')">? unsure</button>' +
      '</div>' +
      '<div class="should-be">' +
        '<span>should be:</span>' +
        '<select class="' + (shouldBe ? 'set' : '') + '" onchange="setShouldBe(\'' + r.image_id + '\', this.value)">' +
          ['', 'good', 'tight', 'wide', 'hidden', 'multi_bug', 'camouflaged']
            .map(v => '<option value="' + v + '"' + (v === (shouldBe || '') ? ' selected' : '') + '>' + (v || '— (no override)') + '</option>')
            .join('') +
        '</select>' +
      '</div>';
    grid.appendChild(div);
  }
}

document.getElementById("source").addEventListener("change", render);
document.getElementById("quality").addEventListener("change", render);
document.getElementById("sort").addEventListener("change", render);
render();

// ─── Mouse-follow zoom ────────────────────────────────────────────
const zoomPopup = document.createElement("img");
zoomPopup.id = "zoomPopup";
document.body.appendChild(zoomPopup);
const ZOOM_MARGIN = 16;
function isZoomTarget(el) {
  return el && el.tagName === "IMG" && el.closest(".imgs figure") && !el.classList.contains("zoom-popup");
}
document.addEventListener("mouseover", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.src = e.target.src;
  zoomPopup.style.display = "block";
});
document.addEventListener("mouseout", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.style.display = "none";
});
document.addEventListener("mousemove", (e) => {
  if (zoomPopup.style.display !== "block") return;
  const zw = zoomPopup.offsetWidth || 560;
  const zh = zoomPopup.offsetHeight || 560;
  let x = e.clientX + ZOOM_MARGIN;
  let y = e.clientY + ZOOM_MARGIN;
  if (x + zw > window.innerWidth - ZOOM_MARGIN) x = e.clientX - zw - ZOOM_MARGIN;
  if (y + zh > window.innerHeight - ZOOM_MARGIN) y = window.innerHeight - zh - ZOOM_MARGIN;
  if (x < ZOOM_MARGIN) x = ZOOM_MARGIN;
  if (y < ZOOM_MARGIN) y = ZOOM_MARGIN;
  zoomPopup.style.left = x + "px";
  zoomPopup.style.top = y + "px";
});
</script>
</body>
</html>

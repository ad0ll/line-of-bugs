<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Framing Validator · {{ variant }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; background: #16141a; color: #f5f5f5; margin: 0; padding: 0; }
  header { position: sticky; top: 0; background: #0d0c10; padding: 12px 24px; border-bottom: 1px solid #28252e; z-index: 10; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  header h1 { margin: 0; font-size: 18px; color: #FF6EC7; }
  header label { font-size: 13px; color: #aaa; }
  header select { background: #16141a; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 8px; }
  header button { background: #FF6EC7; color: #0d0c10; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
  .totals { margin-left: auto; font-size: 13px; color: #aaa; }
  #saveStatus { font-size: 12px; color: #666; margin-left: 8px; }

  .help { font-size: 12px; color: #aaa; padding: 8px 24px; background: #1a1820; border-bottom: 1px solid #28252e; line-height: 1.6; }
  .help code { background: #0d0c10; padding: 1px 6px; border-radius: 3px; color: #FF6EC7; font-family: 'JetBrains Mono', monospace; }
  .help b { color: #f5f5f5; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; padding: 24px; }
  .card { background: #1a1820; border: 1px solid #28252e; border-radius: 8px; padding: 12px; }
  .card.reviewed { border-color: #2d4a2d; }
  .card.flagged  { border-color: #f59e0b; }
  .imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; align-items: start; }
  .imgs figure { margin: 0; }
  .imgs figcaption { font-size: 11px; color: #888; margin-top: 2px; }
  .imgs img { width: 100%; height: auto; background: #0d0c10; border-radius: 4px; display: block; }
  .bbox-overlay { position: relative; display: block; line-height: 0; }
  .bbox-overlay .box { position: absolute; border: 0.2vw solid #FF6EC7; pointer-events: none; box-sizing: border-box; }
  .nocrop { width: 100%; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; background: #0d0c10; color: #666; font-size: 12px; border-radius: 4px; }

  .name { font-size: 14px; margin: 4px 0; color: #f5f5f5; }
  .name code { color: #67D4E6; font-size: 11px; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; margin: 4px 0; font-family: 'JetBrains Mono', monospace; }
  .badge.good          { background: #2d4a2d; color: #a8e6a8; }
  .badge.tight         { background: #2d4a2d; color: #a8e6a8; }
  .badge.wide          { background: #4a3d2d; color: #e6c8a8; }
  .badge.no_bug        { background: #4a2d2d; color: #e6a8a8; }
  .badge.bug_too_small { background: #4a2d2d; color: #e6a8a8; }
  .badge.multi_bug     { background: #4a2d4a; color: #e6a8e6; }
  .badge.poor_contrast { background: #2d3a4a; color: #a8c8e6; }
  .action { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; margin-left: 4px; }
  .metrics { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; margin: 4px 0; line-height: 1.5; }

  /* Multi-select flag buttons */
  .flags { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; margin-top: 8px; }
  .flags button {
    padding: 6px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 11px; font-weight: 400; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .flags button:hover { color: #f5f5f5; border-color: #666; }
  .flags button.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; font-weight: 600; }
  .flags button.good-button.active { background: #2d4a2d; color: #a8e6a8; border-color: #4a7a4a; }
  .flags button.unsure-button.active { background: #28252e; color: #aaa; border-color: #666; }
  /* System-suggested: the badge predicted this reason. Outlined in sky-blue
     so user sees what the system thinks. Click → becomes amber-active (confirmed). */
  .flags button.system-suggested:not(.active) {
    border-color: #67D4E6;
    color: #67D4E6;
    background: rgba(103, 212, 230, 0.08);
  }
  /* "good only ..." preference row — mutually exclusive, sky-blue accent so it
     reads as distinct from the looks-good (approve overall) button. */
  .prefs { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-top: 4px; }
  .prefs button {
    padding: 5px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 11px; font-weight: 400; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .prefs button:hover { color: #f5f5f5; border-color: #666; }
  .prefs button.active { background: #67D4E6; color: #0d0c10; border-color: #67D4E6; font-weight: 600; }
  /* "looks-good" takes the whole first row */
  .flags button.looks-good { grid-column: 1 / -1; padding: 8px; font-weight: 600; }

  /* Zoom popup */
  #zoomPopup {
    position: fixed; z-index: 1000;
    pointer-events: none; display: none;
    line-height: 0;
  }
  #zoomPopup img {
    display: block;
    width: auto; height: auto;
    max-width: 55vw; max-height: 96vh;
    object-fit: contain;
    background: #0d0c10;
    border: 0.2vw solid #FF6EC7; border-radius: 0.3vw;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.7);
  }
  #zoomPopup .zoom-bbox {
    position: absolute;
    border: 0.25vw solid #FF6EC7;
    box-sizing: border-box;
    pointer-events: none;
    display: none;
  }
</style>
</head>
<body>
<header>
  <h1>✿ Framing Validator</h1>
  <label>Variant <select id="variant"><option>{{ variant }}</option></select></label>
  <label>Source <select id="source"><option value="all">all</option>{% for s in sources %}<option value="{{ s }}">{{ s }}</option>{% endfor %}</select></label>
  <label>Predicted <select id="quality"><option value="all">all</option><option value="good">good</option><option value="tight">tight</option><option value="wide">wide</option><option value="no_bug">no_bug</option><option value="bug_too_small">bug_too_small</option><option value="multi_bug">multi_bug</option><option value="poor_contrast">poor_contrast</option></select></label>
  <label>Status <select id="reviewStatus"><option value="all">all</option><option value="unreviewed">unreviewed</option><option value="reviewed">reviewed</option><option value="looks-good">looks-good</option><option value="flagged">any flag</option>
        <option value="pref-original">marked original-good</option>
        <option value="pref-cropped">marked cropped-good</option></select></label>
  <label>Sort <select id="sort"><option value="bbox_area">area ↑</option><option value="bbox_long_edge">long-edge px ↑</option><option value="bbox_min_edge">short-edge px ↑</option><option value="confidence">conf ↑</option><option value="lab_delta_e">ΔE ↑</option><option value="subject_sharpness">sharpness ↑</option><option value="random">random</option></select></label>
  <span class="totals" id="totals">{{ total }} images</span>
  <button onclick="exportLabels()" title="Download all labels as labels.json">Export labels</button>
  <button onclick="document.getElementById('importLabels').click()" title="Load a previously-exported labels.json (merges)">Import labels</button>
  <input type="file" id="importLabels" accept=".json" style="display:none">
  <span id="saveStatus"></span>
</header>

<div class="help">
  <b>What to do:</b> click <code>✓ looks-good</code> when the system's predicted action looks right. Otherwise click ALL flags that apply — these are <em>multi-select</em>, not exclusive. Default state (no click) = unreviewed.
  <br><b>Detection issues:</b>
  <code>bbox-wrong</code> bbox missed the bug / on wrong subject / clipped the body ·
  <code>no-bug</code> there's no insect in the image at all ·
  <code>bug-too-small</code> bug is correctly boxed but too tiny for drawing
  <br><b>Image properties (training data):</b>
  <code>subject-blurred</code> the bug is out of focus (blurred background is fine) ·
  <code>poor-contrast</code> bug nearly indistinguishable from background ·
  <code>multi-bug</code> more than one insect ·
  <code>subject-clipped</code> body runs off the frame edge ·
  <code>other-bad</code> some other reason this image is unusable
  <br><b>Auto-crop:</b>
  <code>crop-too-tight</code> proposed crop clips the bug ·
  <code>crop-too-loose</code> too much background in proposed crop
  <br><b>Skip:</b> <code>? unsure</code> can't decide.
  <br><b>System suggestion:</b> the flag button matching the system's predicted badge is outlined in <span style="color:#67D4E6">sky blue</span>. Click it to explicitly confirm that reason, or just hit <code>✓ looks-good</code> for "system got it right overall."
  <br><b>Optional preference</b> (separate row, mutually exclusive, doesn't affect classification, <em>don't click on every image</em>):
  <code>★ original-good</code> only when the system would crop but you think the original is fine as-is ·
  <code>★ cropped-good</code> only when the system would hide but you think the cropped version rescues it.
  <br><span style="color:#666">Hover any image to zoom. Labels persist via localStorage; auto-export every 25 changes.</span>
</div>

<div class="grid" id="grid"></div>

<script>
const DATA = {{ data_json }};
const LABEL_KEY = "framing_labels";
const SAVE_META_KEY = "framing_labels_meta";

const FLAGS = [
  "bbox-wrong", "no-bug", "bug-too-small",
  "subject-blurred", "poor-contrast", "multi-bug",
  "subject-clipped", "other-bad",
  "crop-too-tight", "crop-too-loose",
];

// When the system predicts one of these badges, the matching FLAG button gets
// a sky-blue outline so the user can see what the system thinks. Clicking it
// confirms (becomes amber). Flags without a system-equivalent (bbox-wrong,
// subject-blurred, subject-clipped, other-bad, crop-too-*) are user-only.
const BADGE_TO_FLAG = {
  "bug_too_small": "bug-too-small",
  "multi_bug":     "multi-bug",
  "no_bug":        "no-bug",
  "poor_contrast": "poor-contrast",
};

const FLAG_TITLES = {
  "bbox-wrong":       "Bbox missed the bug, captured wrong part, or wrong subject",
  "no-bug":           "There's no insect in this image at all",
  "bug-too-small":    "Bug is correctly identified but too tiny for drawing (even after crop)",
  "subject-blurred":  "The bug in the ORIGINAL is out of focus (DOF / camera shake). Blurred background is fine. Blurry crop from over-zooming a small bug is 'bug-too-small' instead.",
  "poor-contrast":    "Bug nearly indistinguishable from background (camouflaged, dim)",
  "multi-bug":        "More than one insect in the image",
  "subject-clipped":  "Bug's body is cut off by the frame edge",
  "other-bad":        "Bad for drawing for some other reason",
  "crop-too-tight":   "Proposed crop cuts off part of the bug",
  "crop-too-loose":   "Proposed crop has too much background",
};

// Map old {status, should_be} fields to flags in the new multi-select model.
// Lossy where the old vocabulary doesn't have a clean new equivalent — we make
// the best guess and tag the entry with `migrated_from` so the user can re-check.
const STATUS_TO_FLAGS = {
  "ok":          { looks_good: true },
  "unsure":      { unsure: true },
  "wrong-bbox":  { flags: ["bbox-wrong"] },
  "wrong-crop":  { flags: ["crop-too-loose"] },  // lossy: was either too-tight or too-loose
  "wrong-class": { flags: [] },                   // lossy: should_be (below) carries the real signal
  "wrong":       { flags: ["other-bad"] },        // very-old single-button-✗ shape
};
const SHOULD_BE_TO_FLAG = {
  "multi_bug":     "multi-bug",
  "camouflaged":   "poor-contrast",
  "poor_contrast": "poor-contrast",
  "blurred":       "subject-blurred",
  "hidden":        "no-bug",
  "no_bug":        "no-bug",
  "bug_too_small": "bug-too-small",
  // good / tight / wide on the old should_be axis meant "this is fine" → looks_good
};
const FRAMING_OK = new Set(["good", "tight", "wide"]);

function _upgradeOldLabel(v) {
  // String-only shape (oldest): treat as wrong-*
  if (typeof v === "string") {
    const mapped = STATUS_TO_FLAGS[v];
    if (mapped) return Object.assign({
      flags: [], looks_good: false, unsure: false,
      reviewed_at: Date.now(), migrated_from: "string:" + v,
    }, mapped);
    return { flags: ["other-bad"], looks_good: false, unsure: false,
             preference: null,
             reviewed_at: Date.now(), migrated_from: "string:" + v };
  }
  // Object with new shape — leave alone.
  if (v && Array.isArray(v.flags)) return v;
  // Object with old {status, should_be} shape — migrate.
  if (v && typeof v === "object") {
    const out = { flags: [], looks_good: false, unsure: false,
                  preference: v.preference || null,
                  reviewed_at: v.reviewed_at || Date.now(),
                  migrated_from: "status:" + (v.status || "—") + "/should_be:" + (v.should_be || "—") };
    const statusMap = v.status ? STATUS_TO_FLAGS[v.status] : null;
    if (statusMap) {
      if (statusMap.looks_good) out.looks_good = true;
      if (statusMap.unsure) out.unsure = true;
      if (statusMap.flags) out.flags.push(...statusMap.flags);
    }
    if (v.should_be) {
      if (FRAMING_OK.has(v.should_be)) {
        // user said "this should be in a fine bucket" — interpret as approval
        out.looks_good = true;
        out.unsure = false;
      } else {
        const flag = SHOULD_BE_TO_FLAG[v.should_be];
        if (flag && !out.flags.includes(flag)) out.flags.push(flag);
        out.looks_good = false;
      }
    }
    return out;
  }
  return { flags: [], looks_good: false, unsure: false, preference: null, reviewed_at: Date.now() };
}

function getLabels() {
  const raw = JSON.parse(localStorage.getItem(LABEL_KEY) || "{}");
  let upgraded = false;
  for (const k of Object.keys(raw)) {
    const v = raw[k];
    if (!v || (typeof v === "object" && Array.isArray(v.flags))) continue;
    raw[k] = _upgradeOldLabel(v);
    upgraded = true;
  }
  // Persist the upgrade once so subsequent reads are clean.
  if (upgraded) {
    try { localStorage.setItem(LABEL_KEY, JSON.stringify(raw)); }
    catch (e) { /* tolerate — render still works in-memory */ }
  }
  return raw;
}
function setLabels(o) {
  try { localStorage.setItem(LABEL_KEY, JSON.stringify(o)); }
  catch (e) { notifySaveError(e.message); }
}
function getSaveMeta() { return JSON.parse(localStorage.getItem(SAVE_META_KEY) || '{"changes_since_export":0,"last_change":null}'); }
function setSaveMeta(m) { try { localStorage.setItem(SAVE_META_KEY, JSON.stringify(m)); } catch (e) {} }
function notifySaveError(msg) {
  const el = document.getElementById("saveStatus");
  if (el) { el.textContent = "save failed: " + msg; el.style.color = "#ef4444"; }
}
function updateSaveStatus() {
  const el = document.getElementById("saveStatus");
  if (!el) return;
  el.style.color = "#666";
  const m = getSaveMeta();
  const labels = getLabels();
  const n = Object.keys(labels).length;
  const reviewed = Object.values(labels).filter(v => v.looks_good || (v.flags && v.flags.length > 0) || v.unsure).length;
  const t = m.last_change ? new Date(m.last_change).toLocaleTimeString() : "—";
  el.textContent = `${reviewed} reviewed · ${n} total · last save ${t}${m.changes_since_export ? " · " + m.changes_since_export + " since export" : ""}`;
}

function bumpSaveMeta() {
  const m = getSaveMeta();
  m.changes_since_export = (m.changes_since_export || 0) + 1;
  m.last_change = Date.now();
  setSaveMeta(m);
  updateSaveStatus();
  if (m.changes_since_export >= 25 && m.changes_since_export % 25 === 0) {
    try { exportLabels(true); } catch (e) { notifySaveError("auto-export: " + e.message); }
  }
}

function toggleFlag(id, flag) {
  const all = getLabels();
  const cur = all[id] || { flags: [], unsure: false, looks_good: false, preference: null, reviewed_at: null };
  // Toggling a flag clears looks_good and unsure (they're mutually exclusive states).
  const i = cur.flags.indexOf(flag);
  if (i >= 0) cur.flags.splice(i, 1);
  else cur.flags.push(flag);
  if (cur.flags.length > 0) { cur.looks_good = false; cur.unsure = false; }
  cur.reviewed_at = Date.now();
  if (cur.flags.length === 0 && !cur.looks_good && !cur.unsure && !cur.preference) delete all[id];
  else all[id] = cur;
  setLabels(all);
  bumpSaveMeta();
  render();
}

function setLooksGood(id) {
  const all = getLabels();
  const cur = all[id] || { flags: [], unsure: false, looks_good: false, preference: null, reviewed_at: null };
  // Toggle looks_good; clears flags and unsure.
  const was = cur.looks_good;
  cur.looks_good = !was;
  if (cur.looks_good) { cur.flags = []; cur.unsure = false; }
  cur.reviewed_at = Date.now();
  if (cur.flags.length === 0 && !cur.looks_good && !cur.unsure && !cur.preference) delete all[id];
  else all[id] = cur;
  setLabels(all);
  bumpSaveMeta();
  render();
}

function setPreference(id, kind) {
  // kind is 'original' | 'cropped' | null. Mutually exclusive.
  const all = getLabels();
  const cur = all[id] || { flags: [], unsure: false, looks_good: false, preference: null, reviewed_at: null };
  cur.preference = (cur.preference === kind) ? null : kind;
  cur.reviewed_at = Date.now();
  if (cur.flags.length === 0 && !cur.looks_good && !cur.unsure && !cur.preference) delete all[id];
  else all[id] = cur;
  setLabels(all);
  bumpSaveMeta();
  render();
}

function setUnsure(id) {
  const all = getLabels();
  const cur = all[id] || { flags: [], unsure: false, looks_good: false, preference: null, reviewed_at: null };
  const was = cur.unsure;
  cur.unsure = !was;
  if (cur.unsure) { cur.flags = []; cur.looks_good = false; }
  cur.reviewed_at = Date.now();
  if (cur.flags.length === 0 && !cur.looks_good && !cur.unsure && !cur.preference) delete all[id];
  else all[id] = cur;
  setLabels(all);
  bumpSaveMeta();
  render();
}

function exportLabels(auto) {
  const data = JSON.stringify(getLabels(), null, 2);
  const blob = new Blob([data], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  const ts = new Date().toISOString().replace(/[:.]/g, "-").slice(0, 19);
  a.download = auto ? ("labels-autosave-" + ts + ".json") : "labels.json";
  a.click();
  const m = getSaveMeta();
  m.changes_since_export = 0;
  setSaveMeta(m);
  updateSaveStatus();
}

document.getElementById("importLabels").addEventListener("change", (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    try {
      const imported = JSON.parse(ev.target.result);
      const cur = getLabels();
      let added = 0;
      for (const [k, v] of Object.entries(imported)) {
        if (typeof v === "string") cur[k] = { flags: [], unsure: false, looks_good: false, reviewed_at: Date.now() };
        else cur[k] = v;
        added++;
      }
      setLabels(cur);
      updateSaveStatus();
      render();
      const el = document.getElementById("saveStatus");
      if (el) { el.textContent = "imported " + added + " labels"; el.style.color = "#a8e6a8"; setTimeout(updateSaveStatus, 2000); }
    } catch (err) { notifySaveError("import: " + err.message); }
  };
  reader.readAsText(file);
  e.target.value = "";
});

function fmtPct(n) { return n === null || n === undefined ? "—" : (n * 100).toFixed(1) + "%"; }
function fmtNum(n, d) { return n === null || n === undefined ? "—" : n.toFixed(d); }

// Predicted action a card's framing_quality implies (purely informational).
function predictedAction(q) {
  if (q === "no_bug" || q === "bug_too_small" || q === "multi_bug" || q === "poor_contrast") return "hide";
  if (q === "wide") return "serve cropped";
  if (q === "good" || q === "tight") return "serve as-is";
  return "(unknown)";
}

function render() {
  const sf = document.getElementById("source").value;
  const qf = document.getElementById("quality").value;
  const rf = document.getElementById("reviewStatus").value;
  const sortBy = document.getElementById("sort").value;
  const labels = getLabels();
  let rows = DATA.filter(r => sf === "all" || r.source === sf);
  rows = rows.filter(r => qf === "all" || r.framing_quality === qf);
  if (rf !== "all") {
    rows = rows.filter(r => {
      const lbl = labels[r.image_id];
      if (rf === "unreviewed") return !lbl;
      if (rf === "reviewed")   return !!lbl;
      if (rf === "looks-good") return lbl && lbl.looks_good;
      if (rf === "flagged")    return lbl && lbl.flags && lbl.flags.length > 0;
      if (rf === "pref-original") return lbl && lbl.preference === "original";
      if (rf === "pref-cropped")  return lbl && lbl.preference === "cropped";
      return true;
    });
  }
  if (sortBy === "random") rows.sort(() => Math.random() - 0.5);
  else if (sortBy === "bbox_area") rows.sort((a, b) => (a.bbox_area_ratio ?? 0) - (b.bbox_area_ratio ?? 0));
  else if (sortBy === "bbox_long_edge") rows.sort((a, b) => (a.bbox_long_edge_px ?? 0) - (b.bbox_long_edge_px ?? 0));
  else if (sortBy === "bbox_min_edge") rows.sort((a, b) => (a.bbox_min_edge_px ?? 0) - (b.bbox_min_edge_px ?? 0));
  else if (sortBy === "confidence") rows.sort((a, b) => (a.confidence ?? 0) - (b.confidence ?? 0));
  else if (sortBy === "lab_delta_e") rows.sort((a, b) => (a.lab_delta_e ?? 999) - (b.lab_delta_e ?? 999));
  else if (sortBy === "subject_sharpness") rows.sort((a, b) => (a.subject_sharpness ?? 1e9) - (b.subject_sharpness ?? 1e9));

  document.getElementById("totals").textContent = rows.length + " of " + DATA.length + " images";
  const grid = document.getElementById("grid");
  grid.innerHTML = "";
  for (const r of rows) {
    const lbl = labels[r.image_id] || { flags: [], unsure: false, looks_good: false };
    const flagged = (lbl.flags && lbl.flags.length > 0);
    const reviewed = lbl.looks_good || flagged || lbl.unsure;
    const div = document.createElement("div");
    div.className = "card" + (reviewed ? " reviewed" : "") + (flagged ? " flagged" : "");

    const boxHTML = r.bbox_x !== null
      ? '<div class="box" style="left:' + (r.bbox_x*100) + '%;top:' + (r.bbox_y*100) + '%;width:' + (r.bbox_w*100) + '%;height:' + (r.bbox_h*100) + '%"></div>'
      : '';
    const cropHTML = r.crop_path
      ? '<img src="' + r.crop_path + '" alt="">'
      : '<div class="nocrop">no crop · ' + r.framing_quality + '</div>';

    const suggestedFlag = BADGE_TO_FLAG[r.framing_quality];
    const flagButtons = FLAGS.map(f => {
      const active = lbl.flags && lbl.flags.indexOf(f) >= 0;
      const suggested = (f === suggestedFlag);
      const classes = [];
      if (active) classes.push("active");
      if (suggested) classes.push("system-suggested");
      const title = FLAG_TITLES[f] + (suggested ? " · system predicts this — click to confirm" : "");
      return '<button title="' + title + '" class="' + classes.join(' ') + '" onclick="toggleFlag(\'' + r.image_id + '\',\'' + f + '\')">' + f + '</button>';
    }).join('');

    div.innerHTML =
      '<div class="imgs">' +
        '<figure>' +
          '<div class="bbox-overlay"><img src="' + r.original_path + '" alt="">' + boxHTML + '</div>' +
          '<figcaption>original · bbox pink</figcaption>' +
        '</figure>' +
        '<figure>' + cropHTML + '<figcaption>proposed crop · what users see</figcaption></figure>' +
      '</div>' +
      '<div class="name">' + (r.common_name || r.taxon_species || "?") + ' <code>· ' + r.image_id + '</code></div>' +
      '<span class="badge ' + r.framing_quality + '">' + r.framing_quality + '</span>' +
      '<span class="action">→ ' + predictedAction(r.framing_quality) + '</span>' +
      '<div class="metrics">' +
        'bbox: ' + fmtPct(r.bbox_area_ratio) + ' (' +
          (r.bbox_long_edge_px !== null && r.bbox_long_edge_px !== undefined ? r.bbox_long_edge_px.toFixed(0) + 'px long' : '—') + ' / ' +
          (r.bbox_min_edge_px !== null && r.bbox_min_edge_px !== undefined ? r.bbox_min_edge_px.toFixed(0) + 'px short' : '—') +
        ') · crop fills: ' + fmtPct(r.post_crop_subject_area) + '<br>' +
        'conf: ' + fmtNum(r.confidence, 2) + ' · ΔE: ' + fmtNum(r.lab_delta_e, 1) + ' · sharpness: ' + fmtNum(r.subject_sharpness, 0) + '<br>' +
        'detected: ' + r.n_distinct_detections + ' bug' + (r.n_distinct_detections === 1 ? '' : 's') +
        (r.bbox_touches_edge ? ' · ⚠ bbox touches frame edge' : '') +
        (r.gt_iou !== null ? ' · gt_iou: ' + r.gt_iou.toFixed(2) : '') +
      '</div>' +
      '<div class="flags">' +
        '<button title="Everything looks correct — system prediction is right" class="looks-good good-button ' + (lbl.looks_good ? 'active' : '') + '" onclick="setLooksGood(\'' + r.image_id + '\')">✓ looks-good</button>' +
        flagButtons +
        '<button title="Ambiguous, come back later" class="unsure-button ' + (lbl.unsure ? 'active' : '') + '" onclick="setUnsure(\'' + r.image_id + '\')">? unsure</button>' +
      '</div>' +
      '<div class="prefs">' +
        '<button title="The original is good for drawing (ignore the crop). Mutually exclusive with cropped-good." class="' + (lbl.preference === "original" ? 'active' : '') + '" onclick="setPreference(\'' + r.image_id + '\', \'original\')">★ original-good</button>' +
        '<button title="The cropped version is good for drawing (the original isn\'t). Mutually exclusive with original-good." class="' + (lbl.preference === "cropped" ? 'active' : '') + '" onclick="setPreference(\'' + r.image_id + '\', \'cropped\')">★ cropped-good</button>' +
      '</div>';
    grid.appendChild(div);
  }
}

document.getElementById("source").addEventListener("change", render);
document.getElementById("quality").addEventListener("change", render);
document.getElementById("reviewStatus").addEventListener("change", render);
document.getElementById("sort").addEventListener("change", render);
render();
updateSaveStatus();

// Mouse-follow zoom popup with bbox-on-original preservation.
const zoomPopup = document.createElement("div");
zoomPopup.id = "zoomPopup";
const zoomImg = document.createElement("img");
const zoomBox = document.createElement("div");
zoomBox.className = "zoom-bbox";
zoomPopup.appendChild(zoomImg);
zoomPopup.appendChild(zoomBox);
document.body.appendChild(zoomPopup);
const ZOOM_MARGIN_VW = 1;
function vwToPx(v) { return v * window.innerWidth / 100; }
function isZoomTarget(el) {
  return el && el.tagName === "IMG" && el.closest(".imgs figure");
}
document.addEventListener("mouseover", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomImg.src = e.target.src;
  const overlay = e.target.closest(".bbox-overlay");
  const box = overlay ? overlay.querySelector(".box") : null;
  if (box) {
    zoomBox.style.cssText = "position:absolute;box-sizing:border-box;display:block;" + box.style.cssText;
    zoomBox.style.border = "0.25vw solid #FF6EC7";
  } else {
    zoomBox.style.display = "none";
  }
  zoomPopup.style.display = "block";
});
document.addEventListener("mouseout", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.style.display = "none";
});
document.addEventListener("mousemove", (e) => {
  if (zoomPopup.style.display !== "block") return;
  const r = zoomPopup.getBoundingClientRect();
  const zw = r.width || vwToPx(50);
  const zh = r.height || vwToPx(50);
  const m = vwToPx(ZOOM_MARGIN_VW);
  let x = e.clientX + m;
  let y = e.clientY + m;
  if (x + zw > window.innerWidth - m) x = e.clientX - zw - m;
  if (y + zh > window.innerHeight - m) y = window.innerHeight - zh - m;
  if (x < m) x = m;
  if (y < m) y = m;
  zoomPopup.style.left = x + "px";
  zoomPopup.style.top = y + "px";
});
</script>
</body>
</html>

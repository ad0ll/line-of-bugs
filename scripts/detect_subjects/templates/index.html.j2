<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Framing Validator · {{ variant }}</title>
<style>
  body { font-family: -apple-system, system-ui, sans-serif; background: #16141a; color: #f5f5f5; margin: 0; padding: 0; }
  header { position: sticky; top: 0; background: #0d0c10; padding: 12px 24px; border-bottom: 1px solid #28252e; z-index: 10; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  header h1 { margin: 0; font-size: 18px; color: #FF6EC7; }
  header label { font-size: 13px; color: #aaa; }
  header select { background: #16141a; color: #f5f5f5; border: 1px solid #444; border-radius: 4px; padding: 4px 8px; }
  header button { background: #FF6EC7; color: #0d0c10; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; }
  .totals { margin-left: auto; font-size: 13px; color: #aaa; }
  #saveStatus { font-size: 12px; color: #666; margin-left: 8px; }

  .help { font-size: 12px; color: #aaa; padding: 8px 24px; background: #1a1820; border-bottom: 1px solid #28252e; line-height: 1.6; }
  .help code { background: #0d0c10; padding: 1px 6px; border-radius: 3px; color: #FF6EC7; font-family: 'JetBrains Mono', monospace; }
  .help b { color: #f5f5f5; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 16px; padding: 24px; }
  .card { background: #1a1820; border: 1px solid #28252e; border-radius: 8px; padding: 12px; }
  .card.reviewed { border-color: #2d4a2d; }
  .card.flagged  { border-color: #f59e0b; }
  .imgs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px; align-items: start; }
  .imgs figure { margin: 0; }
  .imgs figcaption { font-size: 11px; color: #888; margin-top: 2px; }
  .imgs img { width: 100%; height: auto; background: #0d0c10; border-radius: 4px; display: block; }
  .bbox-overlay { position: relative; display: block; line-height: 0; }
  .bbox-overlay .box { position: absolute; border: 0.2vw solid #FF6EC7; pointer-events: none; box-sizing: border-box; }
  /* Secondary detections — other distinct subjects the system clustered.
     Cyan so they contrast against both pink primary and any photo background.
     The ::after pseudo-element shows the DINO confidence as a corner badge —
     low conf (≈0.20) is the noise band where flowers/leaves leak in. */
  .bbox-overlay .box-secondary {
    position: absolute; border: 0.25vw solid #67D4E6;
    pointer-events: none; box-sizing: border-box;
    box-shadow: 0 0 0 0.05vw rgba(0, 0, 0, 0.8);
  }
  .bbox-overlay .box-secondary::after {
    content: attr(data-conf);
    position: absolute; top: -1px; right: -1px;
    background: #67D4E6; color: #0d0c10;
    font: 600 9px/1 'JetBrains Mono', monospace;
    padding: 2px 3px; border-radius: 0 0 0 3px;
  }
  .nocrop { width: 100%; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; background: #0d0c10; color: #666; font-size: 12px; border-radius: 4px; }

  .name { font-size: 14px; margin: 4px 0; color: #f5f5f5; }
  .name code { color: #67D4E6; font-size: 11px; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; margin: 4px 0; font-family: 'JetBrains Mono', monospace; }
  .badge.good          { background: #2d4a2d; color: #a8e6a8; }
  .badge.tight         { background: #2d4a2d; color: #a8e6a8; }
  .badge.wide          { background: #4a3d2d; color: #e6c8a8; }
  .badge.no_bug        { background: #4a2d2d; color: #e6a8a8; }
  .badge.bug_too_small { background: #4a2d2d; color: #e6a8a8; }
  .badge.multi_bug     { background: #4a2d4a; color: #e6a8e6; }
  .badge.poor_contrast { background: #2d3a4a; color: #a8c8e6; }
  .metrics { font-size: 11px; color: #888; font-family: 'JetBrains Mono', monospace; margin: 4px 0; line-height: 1.5; }

  /* Flag buttons — multi-select. Each describes a property of the image. */
  .flags { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; margin-top: 8px; }
  .flags button {
    padding: 6px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 11px; font-weight: 400;
    /* Some flag names (bbox-wrong_*) are very long; allow wrap on whitespace
       AND let the browser break at hyphens/underscores when needed. */
    overflow-wrap: anywhere; line-height: 1.25; min-height: 30px;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .flags button:hover { color: #f5f5f5; border-color: #666; }
  /* System-suggested (pre-selected, unconfirmed): sky-blue. */
  .flags button.suggested {
    border-color: #67D4E6;
    color: #67D4E6;
    background: rgba(103, 212, 230, 0.10);
    font-weight: 600;
  }
  /* User-confirmed / user-toggled-on: amber. */
  .flags button.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; font-weight: 600; }
  .flags button.unsure-button.active { background: #28252e; color: #aaa; border-color: #666; }

  /* Mutually-exclusive original-good / cropped-good row.
     Each can be system-suggested (sky-blue) or user-confirmed (amber). */
  .prefs { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; margin-top: 4px; }
  .prefs button {
    padding: 5px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 11px; font-weight: 400; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .prefs button:hover { color: #f5f5f5; border-color: #666; }
  .prefs button.suggested {
    border-color: #67D4E6;
    color: #67D4E6;
    background: rgba(103, 212, 230, 0.10);
    font-weight: 600;
  }
  .prefs button.active { background: #f59e0b; color: #0d0c10; border-color: #f59e0b; font-weight: 600; }

  /* Review-row: mark-reviewed + unsure. Mark-reviewed gets full width. */
  .review-row { display: grid; grid-template-columns: 3fr 1fr; gap: 4px; margin-top: 8px; }
  .review-row button {
    padding: 8px 4px; border: 1px solid #444; background: #1a1820;
    color: #aaa; border-radius: 4px; cursor: pointer;
    font-size: 12px; font-weight: 600; white-space: nowrap;
    transition: background 0.08s, border-color 0.08s, color 0.08s;
  }
  .review-row button:hover { color: #f5f5f5; border-color: #666; }
  .review-row button.mark-reviewed.active { background: #2d4a2d; color: #a8e6a8; border-color: #4a7a4a; }
  .review-row button.unsure-button.active { background: #28252e; color: #aaa; border-color: #666; }

  /* Zoom popup */
  #zoomPopup {
    position: fixed; z-index: 1000;
    pointer-events: none; display: none;
    line-height: 0;
  }
  #zoomPopup img {
    display: block;
    width: auto; height: auto;
    max-width: 55vw; max-height: 96vh;
    object-fit: contain;
    background: #0d0c10;
    border: 0.2vw solid #FF6EC7; border-radius: 0.3vw;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.7);
  }
  #zoomPopup .zoom-bbox {
    position: absolute;
    border: 0.25vw solid #FF6EC7;
    box-sizing: border-box;
    pointer-events: none;
    display: none;
  }
  #zoomPopup .zoom-bbox-secondary {
    position: absolute;
    border: 0.25vw solid #67D4E6;
    box-shadow: 0 0 0 0.05vw rgba(0, 0, 0, 0.8);
    box-sizing: border-box;
    pointer-events: none;
  }
  #zoomPopup .zoom-bbox-secondary::after {
    content: attr(data-conf);
    position: absolute; top: -1px; right: -1px;
    background: #67D4E6; color: #0d0c10;
    font: 600 0.7vw/1 'JetBrains Mono', monospace;
    padding: 0.15vw 0.25vw; border-radius: 0 0 0 0.25vw;
  }
</style>
</head>
<body>
<header>
  <h1>✿ Framing Validator</h1>
  <label>Variant <select id="variant"><option>{{ variant }}</option></select></label>
  <label>Source <select id="source"><option value="all">all</option>{% for s in sources %}<option value="{{ s }}">{{ s }}</option>{% endfor %}</select></label>
  <label>Predicted <select id="quality"><option value="all">all</option><option value="good">good</option><option value="tight">tight</option><option value="wide">wide</option><option value="no_bug">no_bug</option><option value="bug_too_small">bug_too_small</option><option value="multi_bug">multi_bug</option><option value="poor_contrast">poor_contrast</option></select></label>
  <label>Status <select id="reviewStatus"><option value="all">all</option><option value="unreviewed">unreviewed</option><option value="reviewed">reviewed</option><option value="agreed">agreed with system</option><option value="edited">user edited labels</option><option value="flagged">any flag</option>
        <option value="pref-original">marked original-good</option>
        <option value="pref-cropped">marked cropped-good</option></select></label>
  <label>Sort <select id="sort"><option value="bbox_area">area ↑</option><option value="bbox_long_edge">long-edge px ↑</option><option value="bbox_min_edge">short-edge px ↑</option><option value="confidence">conf ↑</option><option value="lab_delta_e">ΔE ↑</option><option value="subject_sharpness">sharpness ↑</option><option value="random">random</option></select></label>
  <span class="totals" id="totals">{{ total }} images</span>
  <span id="saveStatus" title="Each click is saved to data/cache/labels.json on the server"></span>
</header>

<div class="help">
  <b>What to do:</b> the system pre-selects the labels it thinks apply (outlined in <span style="color:#67D4E6">sky blue</span>). If they look right, click <code>✓ mark reviewed</code>. If not, toggle labels to correct — any edit auto-marks the image reviewed. Labels describe <em>properties</em>, not actions; they're multi-select.
  <br><b>Detection issues:</b>
  <code>bbox-wrong_correct-subject</code> right bug, wrong box position ·
  <code>bbox-wrong_better-subject-other-bbox</code> one of the cyan secondaries is a better choice ·
  <code>no-bug</code> no insect in the image at all ·
  <code>bug-too-small</code> bug is correctly boxed but too tiny for drawing
  <br><b>Image properties:</b>
  <code>subject-blurred</code> the bug is out of focus (blurred background is fine) ·
  <code>poor-contrast</code> bug nearly indistinguishable from background ·
  <code>multi-bug</code> more than one insect ·
  <code>subject-clipped</code> body runs off the frame edge ·
  <code>other-bad</code> some other reason this image is unusable
  <br><b>Crop quality:</b>
  <code>crop-too-tight</code> proposed crop clips the bug ·
  <code>crop-too-loose</code> too much background in proposed crop
  <br><b>Positive labels</b> (mutually exclusive, applies when nothing else does):
  <code>★ original-good</code> bug fills enough of the original frame to draw at full size ·
  <code>★ cropped-good</code> bug is small in the original but the crop rescues it.
  <br><b>Skip:</b> <code>? unsure</code> can't decide — comes back later.
  <br><span style="color:#666">Hover any image to zoom. Every click writes to <code>data/cache/labels.json</code> on the server — refresh-safe, port-change-safe.</span>
</div>

<div class="grid" id="grid"></div>

<script>
const DATA = {{ data_json }};
// Flag buttons (multi-select). original-good / cropped-good live in their own
// mutually-exclusive row and aren't in this list.
const FLAGS = [
  "bbox-wrong_correct-subject", "bbox-wrong_better-subject-other-bbox",
  "no-bug", "bug-too-small",
  "subject-blurred", "poor-contrast", "multi-bug",
  "subject-clipped", "other-bad",
  "crop-too-tight", "crop-too-loose",
];

const FLAG_TITLES = {
  "bbox-wrong_correct-subject":          "Pink primary bbox is on the right bug but positioned wrong (clipped, off-center, too tight/loose around the body)",
  "bbox-wrong_better-subject-other-bbox": "One of the CYAN secondary boxes is on a better subject than the pink primary — system picked the wrong detection",
  "no-bug":           "There's no insect in this image at all",
  "bug-too-small":    "Bug is correctly identified but too tiny for drawing (even after crop)",
  "subject-blurred":  "The bug in the ORIGINAL is out of focus (DOF / camera shake). Blurred background is fine. Blurry crop from over-zooming a small bug is 'bug-too-small' instead.",
  "poor-contrast":    "Bug nearly indistinguishable from background (camouflaged, dim)",
  "multi-bug":        "More than one insect in the image",
  "subject-clipped":  "Bug's body is cut off by the frame edge",
  "other-bad":        "Bad for drawing for some other reason",
  "crop-too-tight":   "Proposed crop cuts off part of the bug",
  "crop-too-loose":   "Proposed crop has too much background",
};

// Suggested-label → preference key for the mutually-exclusive pref row.
const PREF_LABELS = { "original-good": "original", "cropped-good": "cropped" };

// Source of truth: server-owned `data/cache/labels.json`. We mirror it
// in-memory here; every mutation POSTs the full dict back. localStorage
// is no longer used — origin / port changes don't lose work anymore.
let LABELS = {};
let savePending = 0;

function _emptyLabel() {
  return { flags: [], preference: null, unsure: false, reviewed_at: null };
}

function notifySaveError(msg) {
  const el = document.getElementById("saveStatus");
  if (el) { el.textContent = "save failed: " + msg; el.style.color = "#ef4444"; }
}

function updateSaveStatus() {
  const el = document.getElementById("saveStatus");
  if (!el) return;
  if (savePending > 0) {
    el.style.color = "#f59e0b";
    el.textContent = "saving" + (savePending > 1 ? " (" + savePending + " queued)" : "") + "…";
    return;
  }
  el.style.color = "#666";
  const n = Object.keys(LABELS).length;
  const reviewed = Object.values(LABELS).filter(v => !!v.reviewed_at).length;
  el.textContent = reviewed + " reviewed · " + n + " labelled · data/cache/labels.json";
}

async function loadLabelsFromServer() {
  try {
    const res = await fetch("/api/labels", { cache: "no-store" });
    if (!res.ok) throw new Error("HTTP " + res.status);
    const data = await res.json();
    if (data && typeof data === "object") LABELS = data;
  } catch (e) {
    notifySaveError("load: " + e.message);
  }
}

// Coalesce concurrent saves: while one POST is in flight, new mutations
// just queue a re-send when it returns. This keeps the file write rate
// at one-per-click max even with very fast typing.
let saveQueued = false;
async function saveLabelsToServer() {
  if (savePending > 0) { saveQueued = true; return; }
  savePending++;
  updateSaveStatus();
  while (true) {
    saveQueued = false;
    try {
      const res = await fetch("/api/labels", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(LABELS),
      });
      if (!res.ok) throw new Error("HTTP " + res.status + " " + await res.text());
    } catch (e) {
      notifySaveError("save: " + e.message);
      break;
    }
    if (!saveQueued) break;  // nothing new while we were saving — done
  }
  savePending--;
  updateSaveStatus();
}

// Has the user actually started editing this image? Decides whether the
// card shows the system suggestion (sky-blue) or the user's choices (amber).
function isUserEdited(lbl) {
  return !!(lbl && (lbl.user_edited || (lbl.flags && lbl.flags.length > 0) || lbl.preference || lbl.unsure));
}

// On first user interaction, "materialize" the system suggestion into the
// user's flags / preference. After this, the suggestion is no longer shown
// in sky-blue; the user is editing their own copy.
function _ensureMaterialized(cur, suggested) {
  if (cur.user_edited) return;
  if ((cur.flags && cur.flags.length > 0) || cur.preference || cur.unsure) {
    cur.user_edited = true;
    return;
  }
  for (const s of (suggested || [])) {
    if (s in PREF_LABELS) cur.preference = PREF_LABELS[s];
    else if (!cur.flags.includes(s)) cur.flags.push(s);
  }
  cur.user_edited = true;
}

function _persist(id, cur) {
  cur.reviewed_at = Date.now();
  if (!cur.user_edited && cur.flags.length === 0 && !cur.preference && !cur.unsure) {
    delete LABELS[id];
  } else {
    LABELS[id] = cur;
  }
  render();
  saveLabelsToServer();
}

function _suggestedFor(id) {
  for (const r of DATA) if (r.image_id === id) return r.suggested_labels || [];
  return [];
}

function toggleFlag(id, flag) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _suggestedFor(id));
  const i = cur.flags.indexOf(flag);
  if (i >= 0) cur.flags.splice(i, 1);
  else cur.flags.push(flag);
  cur.unsure = false;
  _persist(id, cur);
}

function togglePreference(id, kind) {
  const cur = LABELS[id] || _emptyLabel();
  _ensureMaterialized(cur, _suggestedFor(id));
  cur.preference = (cur.preference === kind) ? null : kind;
  cur.unsure = false;
  _persist(id, cur);
}

function setUnsure(id) {
  const cur = LABELS[id] || _emptyLabel();
  cur.user_edited = true;
  cur.unsure = !cur.unsure;
  if (cur.unsure) { cur.flags = []; cur.preference = null; }
  _persist(id, cur);
}

function markReviewed(id) {
  const cur = LABELS[id] || _emptyLabel();
  if (cur.reviewed_at && cur.user_edited) {
    delete LABELS[id];
    render();
    saveLabelsToServer();
    return;
  }
  _ensureMaterialized(cur, _suggestedFor(id));
  _persist(id, cur);
}

function fmtPct(n) { return n === null || n === undefined ? "—" : (n * 100).toFixed(1) + "%"; }
function fmtNum(n, d) { return n === null || n === undefined ? "—" : n.toFixed(d); }

// Effective view for rendering: if user edited, use their data; else use the
// system suggestion. Returned object has {flags, preference, fromSuggestion}.
function effectiveLabels(r, lbl) {
  if (isUserEdited(lbl)) {
    return { flags: lbl.flags || [], preference: lbl.preference || null, fromSuggestion: false };
  }
  const flags = [];
  let preference = null;
  for (const s of (r.suggested_labels || [])) {
    if (s in PREF_LABELS) preference = PREF_LABELS[s];
    else flags.push(s);
  }
  return { flags, preference, fromSuggestion: true };
}

function render() {
  const sf = document.getElementById("source").value;
  const qf = document.getElementById("quality").value;
  const rf = document.getElementById("reviewStatus").value;
  const sortBy = document.getElementById("sort").value;
  const labels = LABELS;
  let rows = DATA.filter(r => sf === "all" || r.source === sf);
  rows = rows.filter(r => qf === "all" || r.framing_quality === qf);
  if (rf !== "all") {
    rows = rows.filter(r => {
      const lbl = labels[r.image_id];
      if (rf === "unreviewed") return !lbl || !lbl.reviewed_at;
      if (rf === "reviewed")   return lbl && lbl.reviewed_at;
      if (rf === "agreed")     return lbl && lbl.reviewed_at && !lbl.user_edited;
      if (rf === "edited")     return lbl && lbl.user_edited;
      if (rf === "flagged")    return lbl && lbl.flags && lbl.flags.length > 0;
      if (rf === "pref-original") return lbl && lbl.preference === "original";
      if (rf === "pref-cropped")  return lbl && lbl.preference === "cropped";
      return true;
    });
  }
  if (sortBy === "random") rows.sort(() => Math.random() - 0.5);
  else if (sortBy === "bbox_area") rows.sort((a, b) => (a.bbox_area_ratio ?? 0) - (b.bbox_area_ratio ?? 0));
  else if (sortBy === "bbox_long_edge") rows.sort((a, b) => (a.bbox_long_edge_px ?? 0) - (b.bbox_long_edge_px ?? 0));
  else if (sortBy === "bbox_min_edge") rows.sort((a, b) => (a.bbox_min_edge_px ?? 0) - (b.bbox_min_edge_px ?? 0));
  else if (sortBy === "confidence") rows.sort((a, b) => (a.confidence ?? 0) - (b.confidence ?? 0));
  else if (sortBy === "lab_delta_e") rows.sort((a, b) => (a.lab_delta_e ?? 999) - (b.lab_delta_e ?? 999));
  else if (sortBy === "subject_sharpness") rows.sort((a, b) => (a.subject_sharpness ?? 1e9) - (b.subject_sharpness ?? 1e9));

  document.getElementById("totals").textContent = rows.length + " of " + DATA.length + " images";
  const grid = document.getElementById("grid");
  grid.innerHTML = "";
  for (const r of rows) {
    const lbl = labels[r.image_id] || _emptyLabel();
    const eff = effectiveLabels(r, lbl);
    const reviewed = !!lbl.reviewed_at;
    const flagged = eff.flags.length > 0;
    const div = document.createElement("div");
    div.className = "card" + (reviewed ? " reviewed" : "") + (flagged ? " flagged" : "");

    const primaryBoxHTML = r.bbox_x !== null
      ? '<div class="box" style="left:' + (r.bbox_x*100) + '%;top:' + (r.bbox_y*100) + '%;width:' + (r.bbox_w*100) + '%;height:' + (r.bbox_h*100) + '%"></div>'
      : '';
    // Secondary bbox tuple is [x, y, w, h, conf?]. conf added 2026-05-15;
    // older sidecars without conf still render (badge just shows empty).
    const secondaryBoxHTML = (r.secondary_bboxes || []).map(b => {
      const conf = (b.length >= 5 && b[4] != null) ? b[4].toFixed(2) : '';
      return '<div class="box-secondary" data-conf="' + conf + '" style="left:' + (b[0]*100) + '%;top:' + (b[1]*100) + '%;width:' + (b[2]*100) + '%;height:' + (b[3]*100) + '%"></div>';
    }).join('');
    const boxHTML = primaryBoxHTML + secondaryBoxHTML;
    const cropHTML = r.crop_path
      ? '<img src="' + r.crop_path + '" alt="">'
      : '<div class="nocrop">no crop · ' + r.framing_quality + '</div>';

    // Flag buttons. Pre-selected (system) → sky-blue. User-confirmed → amber.
    const flagButtons = FLAGS.map(f => {
      const isOn = eff.flags.indexOf(f) >= 0;
      const cls = !isOn ? "" : (eff.fromSuggestion ? "suggested" : "active");
      const title = FLAG_TITLES[f] + (cls === "suggested" ? " · system suggests this — already selected, click to remove" : "");
      return '<button title="' + title + '" class="' + cls + '" onclick="toggleFlag(\'' + r.image_id + '\',\'' + f + '\')">' + f + '</button>';
    }).join('');

    // Preference row — mutually exclusive original-good / cropped-good.
    const prefBtn = (kind, label, tip) => {
      const on = eff.preference === kind;
      const cls = !on ? "" : (eff.fromSuggestion ? "suggested" : "active");
      const fullTip = tip + (cls === "suggested" ? " · system suggests this — already selected" : "");
      return '<button title="' + fullTip + '" class="' + cls + '" onclick="togglePreference(\'' + r.image_id + '\', \'' + kind + '\')">★ ' + label + '</button>';
    };
    const prefHTML =
      prefBtn("original", "original-good", "Bug fills enough of the original frame to draw at full size. Mutually exclusive with cropped-good.") +
      prefBtn("cropped",  "cropped-good",  "Bug is small in original but the crop rescues it. Mutually exclusive with original-good.");

    div.innerHTML =
      '<div class="imgs">' +
        '<figure>' +
          '<div class="bbox-overlay"><img src="' + r.original_path + '" alt="">' + boxHTML + '</div>' +
          '<figcaption>original · primary <span style="color:#FF6EC7">pink</span>' +
            ((r.secondary_bboxes && r.secondary_bboxes.length) ? ' · <span style="color:#67D4E6">cyan</span> = ' + r.secondary_bboxes.length + ' other detection' + (r.secondary_bboxes.length === 1 ? '' : 's') : '') +
          '</figcaption>' +
        '</figure>' +
        '<figure>' + cropHTML + '<figcaption>proposed crop · what users see</figcaption></figure>' +
      '</div>' +
      '<div class="name">' + (r.common_name || r.taxon_species || "?") + ' <code>· ' + r.image_id + '</code></div>' +
      '<span class="badge ' + r.framing_quality + '">' + r.framing_quality + '</span>' +
      '<div class="metrics">' +
        'bbox: ' + fmtPct(r.bbox_area_ratio) + ' (' +
          (r.bbox_long_edge_px !== null && r.bbox_long_edge_px !== undefined ? r.bbox_long_edge_px.toFixed(0) + 'px long' : '—') + ' / ' +
          (r.bbox_min_edge_px !== null && r.bbox_min_edge_px !== undefined ? r.bbox_min_edge_px.toFixed(0) + 'px short' : '—') +
        ') · crop fills: ' + fmtPct(r.post_crop_subject_area) + '<br>' +
        'conf: ' + fmtNum(r.confidence, 2) + ' · ΔE: ' + fmtNum(r.lab_delta_e, 1) + ' · sharpness: ' + fmtNum(r.subject_sharpness, 0) + '<br>' +
        'detected: ' + r.n_distinct_detections + ' bug' + (r.n_distinct_detections === 1 ? '' : 's') +
        (r.bbox_touches_edge ? ' · ⚠ bbox touches frame edge' : '') +
        (r.gt_iou !== null ? ' · gt_iou: ' + r.gt_iou.toFixed(2) : '') +
      '</div>' +
      '<div class="flags">' + flagButtons + '</div>' +
      '<div class="prefs">' + prefHTML + '</div>' +
      '<div class="review-row">' +
        '<button class="mark-reviewed ' + (reviewed ? 'active' : '') + '" onclick="markReviewed(\'' + r.image_id + '\')" title="Confirms the current labels (accepts the system suggestion if you haven\'t changed anything). Any label edit auto-marks reviewed.">' +
          (reviewed ? '✓ reviewed' : '✓ mark reviewed') +
        '</button>' +
        '<button class="unsure-button ' + (lbl.unsure ? 'active' : '') + '" onclick="setUnsure(\'' + r.image_id + '\')" title="Ambiguous — come back later">? unsure</button>' +
      '</div>';
    grid.appendChild(div);
  }
}

document.getElementById("source").addEventListener("change", render);
document.getElementById("quality").addEventListener("change", render);
document.getElementById("reviewStatus").addEventListener("change", render);
document.getElementById("sort").addEventListener("change", render);

// Initial paint with empty LABELS so the grid is up immediately; then fetch
// from server and re-render. The fetch is fast (single file read) and keeps
// the first paint feeling instant on cold loads of the 360-image grid.
render();
updateSaveStatus();
loadLabelsFromServer().then(() => { render(); updateSaveStatus(); });

// Mouse-follow zoom popup with bbox-on-original preservation.
const zoomPopup = document.createElement("div");
zoomPopup.id = "zoomPopup";
const zoomImg = document.createElement("img");
const zoomBox = document.createElement("div");
zoomBox.className = "zoom-bbox";
zoomPopup.appendChild(zoomImg);
zoomPopup.appendChild(zoomBox);
document.body.appendChild(zoomPopup);
const ZOOM_MARGIN_VW = 1;
function vwToPx(v) { return v * window.innerWidth / 100; }
function isZoomTarget(el) {
  return el && el.tagName === "IMG" && el.closest(".imgs figure");
}
document.addEventListener("mouseover", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomImg.src = e.target.src;
  const overlay = e.target.closest(".bbox-overlay");
  // Wipe any previously-mirrored secondary boxes; we'll re-create them below.
  [...zoomPopup.querySelectorAll(".zoom-bbox-secondary")].forEach(n => n.remove());
  const box = overlay ? overlay.querySelector(".box") : null;
  if (box) {
    zoomBox.style.cssText = "position:absolute;box-sizing:border-box;display:block;" + box.style.cssText;
    zoomBox.style.border = "0.25vw solid #FF6EC7";
  } else {
    zoomBox.style.display = "none";
  }
  // Mirror every secondary bbox into the zoomed overlay so they scale with it.
  if (overlay) {
    for (const sb of overlay.querySelectorAll(".box-secondary")) {
      const mirror = document.createElement("div");
      mirror.className = "zoom-bbox-secondary";
      mirror.style.cssText = sb.style.cssText;
      if (sb.dataset.conf) mirror.dataset.conf = sb.dataset.conf;
      zoomPopup.appendChild(mirror);
    }
  }
  zoomPopup.style.display = "block";
});
document.addEventListener("mouseout", (e) => {
  if (!isZoomTarget(e.target)) return;
  zoomPopup.style.display = "none";
});
document.addEventListener("mousemove", (e) => {
  if (zoomPopup.style.display !== "block") return;
  const r = zoomPopup.getBoundingClientRect();
  const zw = r.width || vwToPx(50);
  const zh = r.height || vwToPx(50);
  const m = vwToPx(ZOOM_MARGIN_VW);
  let x = e.clientX + m;
  let y = e.clientY + m;
  if (x + zw > window.innerWidth - m) x = e.clientX - zw - m;
  if (y + zh > window.innerHeight - m) y = window.innerHeight - zh - m;
  if (x < m) x = m;
  if (y < m) y = m;
  zoomPopup.style.left = x + "px";
  zoomPopup.style.top = y + "px";
});
</script>
</body>
</html>
